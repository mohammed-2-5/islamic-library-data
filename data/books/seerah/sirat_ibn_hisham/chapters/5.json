{
  "book_id": "sirat_ibn_hisham",
  "chapter_id": 5,
  "title_ar": "المتن",
  "title_en": "",
  "entries": [
    {
      "id": 4735,
      "text_ar": "فهرست الجزء الثاني من سيرة ابن هشام:",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4736,
      "text_ar": "ص الموضوع",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4737,
      "text_ar": "3 خبر الصحيفة ائتمار قريش بالرسول عليه السلام تهكم أبي لهب بالرسول وما نزل فيه من القرآن",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4738,
      "text_ar": "4 شعر أبي طالب في تظاهر قريش أبو جهل يحكم الحصار على المسلمين",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4739,
      "text_ar": "5 ذكر ما لقى رسول الله صلى الله عليه وسلم من قومه من الأذى",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4740,
      "text_ar": "ما نزل من القرآن في أبي لهب وامرأته",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4741,
      "text_ar": "6 أم جميل امرأة أبي لهب إيذاء أمية بن خلف للرسول",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4742,
      "text_ar": "7 إيذاء العاص للرسول",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4743,
      "text_ar": "إيذاء أبي جهل للرسول",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4744,
      "text_ar": "إيذاء النضر للرسول",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4745,
      "text_ar": "8 ابن الزبعرى وما قيل فيه",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4746,
      "text_ar": "9 الأخنس وما أنزل فيه الوليد وما أنزل فيه أبي بن خلف وعقبة بن أبي معيط وما أنزل فيهما",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4747,
      "text_ar": "10 سورة \"الكافرون\" وسبب نزولها أبو جهل وما نزل فيه",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4748,
      "text_ar": "11 تفسير لفظ المهل",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4749,
      "text_ar": "ابن أم مكتوم والوليد وسورة عبس",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4750,
      "text_ar": "12 العائدون من أرض الحبشة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4751,
      "text_ar": "14 عثمان بن مظعون يرد جوار الوليد",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4752,
      "text_ar": "15 أبو سلمة في جوار أبي طالب",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4753,
      "text_ar": "16 دخول أبي بكر في جوار بن الدغنة ورده عليه",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4754,
      "text_ar": "17 حديث نقض الصحيفة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4755,
      "text_ar": "22 إسلام الطفيل بن عمرو الدوسي",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4756,
      "text_ar": "23 إسلام والد الطفيل وزوجه",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4757,
      "text_ar": "25 قصة أعشى بني قيس بن ثعلبة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4758,
      "text_ar": "26 نهاية الأعشى",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4759,
      "text_ar": "27 أبو جهل والإراشي",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4760,
      "text_ar": "27 ركانة المصلي ومصارعته للنبي صلى الله عليه وسلم قدوم وفد النصارى من الحبشة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4761,
      "text_ar": "30 سبب نزول سورة الكوثر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4762,
      "text_ar": "معنى الكوثر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4763,
      "text_ar": "31 نزول \"وقالوا لولا نزل عليه ملك\" نزول \"ولقد استهزئ برسل من قبلك\"",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4764,
      "text_ar": "32 ذكر الإسراء والمعراج رواية ابن مسعود عن الإسراء رواية الحسن",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4765,
      "text_ar": "33 رواية قتادة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4766,
      "text_ar": "ص الموضوع",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4767,
      "text_ar": "33 عودة إلى رواية الحسن",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4768,
      "text_ar": "34 رواية عائشة، رواية معاوية، الإسراء رؤيا",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4769,
      "text_ar": "35 وصف إبراهيم وموسى وعيسى علي يصف الرسول صلى الله عليه وسلم",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4770,
      "text_ar": "36 رواية أم هانئ عن الإسراء قصة المعراج",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4771,
      "text_ar": "40 المستهزئون بالرسول وكفاية الله أمرهم",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4772,
      "text_ar": "41 قصة أبي أزيهر الدوسي",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4773,
      "text_ar": "44 دوس تحاول الثأر لأبي أزيهر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4774,
      "text_ar": "45 أم غيلان وأم جميل، وفاة أبي طالب وخديجة وما عاناه الرسول صلى الله عليه وسلم بعدهما",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4775,
      "text_ar": "46 المشركون يطلبون عهد بينهم وبين الرسول قبل موت أبي طالب",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4776,
      "text_ar": "47 رجاء الرسول إسلام أبي طالب وما نزل فيمن طلبوا العهد على الرسول عند أبي طالب، سعى الرسول إلى الطائف وموقف ثقيف منه",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4777,
      "text_ar": "49 وفد جن نصيبين",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4778,
      "text_ar": "50 عرض رسول الله صلى الله عليه وسلم نفسه على القبائل عرض نفسه في المواسم",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4779,
      "text_ar": "53 إسلام إياس بن معاذ وقصة أبي الحيسر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4780,
      "text_ar": "54 إسلام الأنصار",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4781,
      "text_ar": "55 أسماء من التقوا به صلى الله عليه وسلم من الخزرج",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4782,
      "text_ar": "56 بيعة العقبة الأولى",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4783,
      "text_ar": "57 نص البيعة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4784,
      "text_ar": "58 إرسال مصعب بن عمير مع وفد العقبة أول جمعة أقيمت بالمدينة إسلام سعد بن معاذ وأسيد بن حضير",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4785,
      "text_ar": "61 أمر العقبة الثاني البراء بن معرور يصلي إلى الكعبة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4786,
      "text_ar": "63 إسلام عبد الله بن حرام، لامرأتان في البيعة، العباس يستوثق من الأنصار، عهد الرسول على الأنصار",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4787,
      "text_ar": "65 أسماء النقباء الاثنى عشر، نقباء الخزرج، نقباء الأوس، شعر كعب بن مالك في النقباء",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4788,
      "text_ar": "66 ما قاله العباس بن عبادة للخزرج",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4789,
      "text_ar": "67 أول من ضرب على يد الرسول في بيعة العقبة الثانية، الشيطان يصرخ بعد بيعة العقبة الأنصار تستعجل الحرب",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4790,
      "text_ar": "67 قريس تجادل الأنصار، قريس تأسر سعد بن عبادة، خلاص سعد",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4791,
      "text_ar": "70 قصة صنم عمرو بن الجموح",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4792,
      "text_ar": "71 إسلام عمرو وما قاله من الشعر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4793,
      "text_ar": "72 شروط البيعة في العقبة الأخيرة، أسماء من شهد العقبة الأخيرة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4794,
      "text_ar": "79 نزول الأمر لرسول الله صلى الله عليه وسلم في القتال",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4795,
      "text_ar": "80 الإذن لمسلمي مكة بالهجرة إلى المدينة ذكر المهاجرين إلى المدينة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4796,
      "text_ar": "85 هجرة عمرو قصة عياش وهشام معه",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4797,
      "text_ar": "86 أمر الوليدين الوليد مع عياش وهشام منازل المهاجرين بالمدينة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4798,
      "text_ar": "89 هجرة الرسول صلى الله عليه وسلم قريش تتشاور في أمره",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4799,
      "text_ar": "91 استخلافه لعلي",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4800,
      "text_ar": "92 ما نزر في تربص المشركين بالنبي وأبو بكر يطمع في المصاحبة، حديث الهجرة إلى المدينة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4801,
      "text_ar": "93 في الغار",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4802,
      "text_ar": "94 من قام بشأن الرسول في الغار سبب تسمية أسماء بذات النطاق راحلة الرسول",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4803,
      "text_ar": "95 أبو جهل يضرب أسماء الجني الذي تغنى بمقدمه صلى الله عليه وسلم نسب أم معبد",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4804,
      "text_ar": "96 موقف آل أبي بكر بعد الهجرة سراقة بن مالك",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4805,
      "text_ar": "97 طريق الهجرة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4806,
      "text_ar": "97 قدومه صلى الله عليه وسلم قباء",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4807,
      "text_ar": "100 مسجد قباء، خروج الرسول من قباء وذهابه إلى المدينة، واعتراض القبائل له لينزل عندها",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4808,
      "text_ar": "101 مبرك الناقة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4809,
      "text_ar": "102 مسجد المدينة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4810,
      "text_ar": "عمار والفئة الباغية",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4811,
      "text_ar": "103 الرسول ينزل في بيت أبي أيوب",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4812,
      "text_ar": "104 أبو سفيان وبنو جحش",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4813,
      "text_ar": "105 خطبة رسول الله صلى الله عليه وسلم",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4814,
      "text_ar": "106 الرسول يوادع اليهود",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4815,
      "text_ar": "108 المؤاخاة بين المهاجرين والأنصار",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4816,
      "text_ar": "110 أبو أمامة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4817,
      "text_ar": "111 خبر الأذان",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4818,
      "text_ar": "112 ما كان يدعو به بلال قبل الفجر، أبو قيس بن أبي أنس",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4819,
      "text_ar": "115 عداوة اليهود",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4820,
      "text_ar": "118 إسلام عبد الله بن سلام",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4821,
      "text_ar": "119 حديث صفية، المنافقون بالمدينة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4822,
      "text_ar": "125 المنافقون من أحبار اليهود، طرد المنافقين من المسجد",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4823,
      "text_ar": "127 ما نزل في اليهود والمنافقين",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4824,
      "text_ar": "137 سؤال اليهود الرسول وإجابته اليهود ينكرون نبوة سليمان ورد الله عليهم",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4825,
      "text_ar": "137 كتابه صلى الله عليه وسلم إلى يهود خيبر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4826,
      "text_ar": "163 كفالة جريج لمريم",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4827,
      "text_ar": "164 رفع عيسى عليه السلام",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4828,
      "text_ar": "165 إباء النصارى الملاعنة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4829,
      "text_ar": "166 أبو عبيدة يتولى أمرهم، أخبار عن المنافقين",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4830,
      "text_ar": "169 ذكر من اعتل من أصحاب رسول الله صلى الله عليه وسلم، دعاء الرسول بنقل وباء المدينة إلى مهيعة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4831,
      "text_ar": "170 بدء قتال المشركين، تاريخ الهجرة، غزوة ودان وهي أول غزواته عليه الصلاة والسلام",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4832,
      "text_ar": "171 سرية عبيدة بن الحارث وهي أول راية عقدها عليه الصلاة والسلام",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4833,
      "text_ar": "174 سرية حمزة إلى سيف البحر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4834,
      "text_ar": "176 غزوة بواط، غزوة العشيرة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4835,
      "text_ar": "178 سرية سعد بن أبي وقاص، غزوة سفوان \"وهي غزوة بدر الأولى\"، سرية عبد الله بن جحش ونزول \"يسألونك عن الشهر الحرام\"",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4836,
      "text_ar": "181 صرف القبلة إلى الكعبة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4837,
      "text_ar": "182 غزوة بدر الكبرى، رؤيا عاتكة بنت عبد المطلب",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4838,
      "text_ar": "184 قريش تتجهز للخروج، ما وقع بين قريش وكنانة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4839,
      "text_ar": "186 خروج الرسول صلى الله عليه وسلم، اللواء والرايتان، عدد إبل المسلمين إلى بدر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4840,
      "text_ar": "187 الطريق إلى بدر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4841,
      "text_ar": "188 استشارة الأنصار",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4842,
      "text_ar": "190 نجاة أبي سفيان بالعير",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4843,
      "text_ar": "191 قريش تنزل بالعدوة والمسلمون ببدر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4844,
      "text_ar": "193 الحنظلية ونسبها",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4845,
      "text_ar": "194 مقتل الأسود بن عبد الأسد المخزومي",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4846,
      "text_ar": "195 دعاء عتبة إلى المبارزة، التقاء الفريقين ضرب الرسول لابن غزية",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4847,
      "text_ar": "196 الرسول يناشد ربه النصر، أول شهيد من المسلمين",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4848,
      "text_ar": "198 مقتل أمية بن خلف",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4849,
      "text_ar": "199 الملائكة تشهد وقعة بدر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4850,
      "text_ar": "200 مقتل أبي جهل",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4851,
      "text_ar": "202 حديث عكاشة بن محصن",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4852,
      "text_ar": "203 طرح المشركين في القلب",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4853,
      "text_ar": "204 شعر حسان في ذلك",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4854,
      "text_ar": "205 الفتية الذين نزل فيهم \"إن الذين توفاهم الملائكة ظالمي أنفسهم\"",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4855,
      "text_ar": "206 في بدر، الرجوع إلى المدينة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4856,
      "text_ar": "208 مقتل النضر وعقبة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4857,
      "text_ar": "209 بلوغ مصاب قريش في رجالها إلى مكة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4858,
      "text_ar": "211 فداء سهيل بن عمرو",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4859,
      "text_ar": "212 أسر عمرو بن أبي سفيان",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4860,
      "text_ar": "213 قصة زينب بنت الرسول وزوجها أبي العاص",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4861,
      "text_ar": "215 خروج زينب إلى المدينة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4862,
      "text_ar": "217 إسلام أبي العاص بن الربيع",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4863,
      "text_ar": "220 إسلام عمير بن وهب وتحريض صفوان على قتل الرسول",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4864,
      "text_ar": "223 المطعمون من قريش",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4865,
      "text_ar": "224 نزول سورة الأنفال تصف أحداث بدر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4866,
      "text_ar": "232 من حضر بدرا من المسلمين",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4867,
      "text_ar": "251 من استشهد من المسلمين يوم بدر من قتل ببدر من المشركين",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4868,
      "text_ar": "257 ذكر أسرى قريش يوم بدر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4869,
      "text_ar": "259 ما قيل من الشعر يوم بدر",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4870,
      "text_ar": "تمت الفهرسة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4871,
      "text_ar": "129 ما نزل في أبي ياسر وأخيه",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4872,
      "text_ar": "140 كفر اليهود بالإسلام وما نزل في ذلك",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4873,
      "text_ar": "141 تنازع اليهود والنصارى عنده صلى الله عليه وسلم",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4874,
      "text_ar": "142 ما قالته اليهود عند صرف القبلة إلى الكعبة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4875,
      "text_ar": "143 كتمانهم ما في التوراة، جوابهم حينما دعوا إلى الإسلام جمعهم في سوق بني قينقاع",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4876,
      "text_ar": "144 دخلوه صلى الله عليه وسلم بين المدراس، تنازع اليهود والنصارى في إبراهيم عليه السلام، ما نزل في إيمانهم غدوة وكفرهم عشيا",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4877,
      "text_ar": "145 ما نزل في قول أبي رافع أتريد أن نعبدك كما تعبد النصارى عيسى",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4878,
      "text_ar": "146 ما نزل في أخذ الميثاق عليهم سعيهم في الوقعية بين الأنصار يوم بعاث",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4879,
      "text_ar": "147 ما نزل في قولهم: ما اتبع محمد إلا شرارنا",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4880,
      "text_ar": "148 ما نزل في نهي المسلمين عن مباطنة اليهود، دخول أبي بكر بيت المدارس",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4881,
      "text_ar": "149 أمر اليهود المؤمنين بالبخل",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4882,
      "text_ar": "150 اليهود يجحدون الحق",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4883,
      "text_ar": "151 من حزبوا الأحزاب، إنكار اليهود التنزيل",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4884,
      "text_ar": "151 اتفاقهم على طرح الصخرة عليه صلى الله عليه وسلم",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4885,
      "text_ar": "152 ادعاؤهم أنهم أحباء الله، إنكارهم نزول كتاب بعد موسى رجوعهم إلى النبي صلى الله عليه وسلم في حكم الرجم",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4886,
      "text_ar": "154 ظلمهم في الدية، رغبتهم في فتنة الرسول",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4887,
      "text_ar": "155 إنكارهم نبوة عيسى عليه السلام ادعاؤهم أنهم على حق، إشراكهم بالله، نهى المؤمنين عن موادتهم",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4888,
      "text_ar": "156 سؤالهم عن قيام الساعة، ادعاؤهم أن عزيزا ابن الله",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4889,
      "text_ar": "157 طلبهم كتابا من السماء، سؤالهم عن ذي القرنين، تهجمهم على ذات الله",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4890,
      "text_ar": "158 ذكر نصارى نجران وما نزل فيهم معنى العاقب والسيد والأسقف",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4891,
      "text_ar": "159 إسلام كوز بن علقمة",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4892,
      "text_ar": "رؤساء نجران وإسلام ابن رئيس صلاتهم إلى جهة المشرق",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4893,
      "text_ar": "160 أسماؤهم ومعتقداتهم، ما نزل فيهم من القرآن",
      "text_en": "",
      "reference": "الفهارس"
    },
    {
      "id": 4894,
      "text_ar": "162 ما نزل فيما اتبعه اليهود والنصارى ما نزل في وعظ المرمنين وتحذيرهم ما نزل في خلق عيسى وخبر مريم وزكريا",
      "text_en": "",
      "reference": "الفهارس"
    }
  ]
}