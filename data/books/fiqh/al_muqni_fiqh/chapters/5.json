{
  "book_id": "al_muqni_fiqh",
  "chapter_id": 5,
  "title_ar": "إن أحرم منفردا ثم نوى الائتمام",
  "title_en": "",
  "entries": [
    {
      "id": 601,
      "text_ar": "وهي أفضل تطوع البدن.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 602,
      "text_ar": "وآكدها صلاة الكسوف والاستسقاء",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 603,
      "text_ar": "ثم الوتر وليس بواجب",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 604,
      "text_ar": "ووقته ما بين",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 605,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 606,
      "text_ar": "صلاة العشاء وطلوع الفجر",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 607,
      "text_ar": "وأقله ركعة وأكثره إحدى عشرة ركعة، يسلم من كل",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 608,
      "text_ar": "ركعتين ويوتر بواحدة",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 609,
      "text_ar": "وإن أوتر بتسع سرد ثمانيا وجلس، فتشهد ولم يسلم، ثم",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 610,
      "text_ar": "صلى التاسعة وتشهد وسلم. وكذلك السبع، وإن أوتر بخمس، لم يجلس إلا في",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 611,
      "text_ar": "آخرهن، وأدنى الكمال ثلاث ركعات بتسليمتين.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 612,
      "text_ar": "يقرأ في الأولى بعد فاتحة الكتاب:",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 613,
      "text_ar": "\" سبح \"، وفي الثانية: \" قل يا أيها الكافرون \"، وفي الثالثة: \" قل هو الله أحد \"",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 614,
      "text_ar": "ويقنت فيها",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 615,
      "text_ar": "بعد الركوع، فيقول: اللهم إنا نستعينك ونستهديك ونستغفرك، ونتوب إليك ونؤمن",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 616,
      "text_ar": "بك، ونتوكل عليك، ونثني عليك الخير كله، نشكرك ولا نكفرك، اللهم إياك نعبد، ولك نصلي ونسجد، وإليك نسعى ونحفد، ونخشى عذابك، إن عذابك الجد",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 617,
      "text_ar": "بالكفار ملحق. اللهم اهدنا فيمن هديت، وعافنا فيمن عافيت، وبارك لنا فيما أعطيت، وتولنا فيمن توليت، وقنا شر ما قضيت، إنك تقضي ولا يقضى عليك، إنه لا يذل من واليت ، ولا يعز من عاديت، تباركت ربنا وتعاليت. اللهم إنا نعوذ برضاك",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 618,
      "text_ar": "من سخطك، وبعفوك من عقوبتك، وبك منك، لا نحصي ثناء عليك، أنت كما",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 619,
      "text_ar": "أثنيت على نفسك.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 620,
      "text_ar": "وهل يمسح وجهه بيديه؟ على روايتين.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 621,
      "text_ar": "ولا يقنت في غير الوتر إلا أن",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 622,
      "text_ar": "تنزل بالمسلمين نازلة، فللإمام خاصة القنوت في صلاة الفجر.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 623,
      "text_ar": "ثم السنن الراتبة، وهي",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 624,
      "text_ar": "عشر ركعات: ركعتان قبل الظهر، وركعتان بعدها، وركعتان بعد المغرب، وركعتان",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 625,
      "text_ar": "بعد العشاء، وركعتان قبل الفجر، وهما آكدها.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 626,
      "text_ar": "وقال أبو الخطاب: وأربع قبل العصر.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 627,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 628,
      "text_ar": "ومن فاته شيء من هذه السنن سن له قضاؤه.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 629,
      "text_ar": "ثم التراويح، وهي عشرون ركعة، يقوم",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 630,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 631,
      "text_ar": "بها في رمضان في جماعة، ويوتر بعدها في الجماعة، فإن كان له تهجد جعل الوتر",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 632,
      "text_ar": "بعده، وإن أحب متابعة الإمام، فأوتر معه قام إذا سلم الإمام فشفعها بأخرى.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 633,
      "text_ar": "ويكره التطوع بين التراويح، وفي التعقيب روايتان، وهو أن يتطوع بعد التراويح",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 634,
      "text_ar": "والوتر في جماعة.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 635,
      "text_ar": "وصلاة الليل أفضل من النهار، وأفضلها وسط الليل،",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 636,
      "text_ar": "والنصف الأخير أفضل من الأول.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 637,
      "text_ar": "وصلاة الليل مثنى مثنى، وإن تطوع في",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 638,
      "text_ar": "النهار بأربع، فلا بأس. والأفضل مثنى.",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 639,
      "text_ar": "وصلاة القاعد على النصف من صلاة",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 640,
      "text_ar": "القائم، ويكون في حال القيام متربعا",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 641,
      "text_ar": "وأدنى",
      "text_en": "",
      "reference": "باب صلاة التطوع"
    },
    {
      "id": 642,
      "text_ar": "ركعتان، وأكثرها ثمان،",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 643,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 644,
      "text_ar": "ووقتها إذا علت الشمس.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 645,
      "text_ar": "وهل يصح التطوع بركعة، على روايتين.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 646,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 647,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 648,
      "text_ar": "وسجود التلاوة صلاة.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 649,
      "text_ar": "وهو سنة للقارئ والمستمع دون السامع",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 650,
      "text_ar": "ويعتبر أن يكون",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 651,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 652,
      "text_ar": "القارئ يصلح إماما له، فإن لم يسجد القارئ لم يسجد.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 653,
      "text_ar": "وهو أربع عشرة سجدة",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 654,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 655,
      "text_ar": "في الحج منها اثنتان",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 656,
      "text_ar": "ويكبر إذا سجد، وإذا رفع، ويجلس ويسلم، ولا يتشهد.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 657,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 658,
      "text_ar": "سجد في الصلاة رفع يديه، نص عليه، وقال القاضي: لا يرفعهما، ولا يستحب للإمام السجود في صلاة لا يجهر فيها. فإن فعل، فالمأموم مخير بين اتباعه",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 659,
      "text_ar": "وتركه.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 660,
      "text_ar": "ويستحب سجود الشكر عند تجدد النعم واندفاع النقم، ولا يسجد له في الصلاة.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 661,
      "text_ar": "في أوقات النهي",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 662,
      "text_ar": "وهي خمسة: بعد الفجر حتى تطلع الشمس، وبعد العصر حتى تغرب، وعند",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 663,
      "text_ar": "طلوع الشمس حتى ترتفع قيد رمح، وعند قيامها حتى تزول، وإذا تضيفت للغروب",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 664,
      "text_ar": "حتى تغرب",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 665,
      "text_ar": "ويجوز قضاء الفرائض فيها، وتجوز صلاة الجنازة، وركعتا الطواف،",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 666,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 667,
      "text_ar": "وإعادة الجماعة إذا أقيمت وهو في المسجد بعد الفجر والعصر.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 668,
      "text_ar": "وهل تجوز في الثلاثة الباقية؛ على روايتين، ولا يجوز التطوع بغيرها في شيء من هذه الأوقات الخمسة.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 669,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 670,
      "text_ar": "إلا ما له سبب، كتحية المسجد، وسجود التلاوة، وصلاة الكسوف، وقضاء السنن الراتبة، فإنها على روايتين.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 671,
      "text_ar": "باب صلاة الجماعة وهي واجبة للصلوات الخمس على الرجال، لا شرط.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 672,
      "text_ar": "وله فعلها في بيته",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 673,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 674,
      "text_ar": "في أصح الروايتين",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 675,
      "text_ar": "ويستحب لأهل الثغر الاجتماع في مسجد واحد، والأفضل",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 676,
      "text_ar": "لغيرهم الصلاة في المسجد الذي لا تقام فيه الجماعة إلا بحضوره.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 677,
      "text_ar": "ثم ما كان أكثر جماعة، ثم في المسجد العتيق، وهل الأولى قصد الأبعد أو الأقرب، على",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 678,
      "text_ar": "روايتين",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 679,
      "text_ar": "ولا يؤم في مسجد قبل إمامه الراتب إلا بإذنه. إلا أن يتأخر لعذر، فإن لم يعلم عذره انتظر وروسل ما لم يخش خروج الوقت.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 680,
      "text_ar": "فإن صلى ثم أقيمت",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 681,
      "text_ar": "الصلاة وهو في المسجد استحب له إعادتها، إلا المغرب.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 682,
      "text_ar": "وعنه: يعيدها ويشفعها",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 683,
      "text_ar": "برابعة",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 684,
      "text_ar": "ولا تكره إعادة الجماعة في غير المساجد الثلاثة",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 685,
      "text_ar": "وإذا أقيمت الصلاة، فلا",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 686,
      "text_ar": "صلاة إلا المكتوبة، وإن أقيمت وهو في نافلة أتمها إلا أن يخشى فوات الجماعة، فيقطعها، وعنه: يتمها",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 687,
      "text_ar": "ومن كبر قبل سلام الإمام فقد أدرك الجماعة، ومن أدرك",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 688,
      "text_ar": "الركوع فقد أدرك الركعة وأجزأته تكبيرة واحدة، والأفضل اثنتان.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 689,
      "text_ar": "وما أدرك مع",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 690,
      "text_ar": "الإمام فهو آخر صلاته، وما يقضيه أولها، يستفتح ويتعوذ، ويقرأ السورة.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 691,
      "text_ar": "ولا تجب",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 692,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 693,
      "text_ar": "القراءة على المأموم. ويستحب أن يقرأ في سكتات الإمام، وما لا يجهر فيه، أو",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 694,
      "text_ar": "لا يسمعه لبعده، فإن لم يسمعه لطرش فعلى وجهين، وهل يستفتح ويستعيذ",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 695,
      "text_ar": "فيما يجهر فيه الإمام؟ على روايتين",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 696,
      "text_ar": "ومن ركع أو سجد قبل إمامه، فعليه أن",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 697,
      "text_ar": "يرفع ليأتي به بعده. فإن لم يفعل عمدا بطلت صلاته عند أصحابنا إلا القاضي،",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 698,
      "text_ar": "فإن ركع ورفع قبل ركوع إمامه عالما عمدا فهل تبطل صلاته؟ على وجهين. وإن كان جاهلا أو ناسيا لم تبطل، وهل تبطل تلك الركعة؟ على روايتين، فإن ركع",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 699,
      "text_ar": "ورفع قبل ركوعه، ثم سجد قبل رفعه، بطلت صلاته إلا الجاهل والناسي تصح صلاتهما، وتبطل تلك الركعة.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 700,
      "text_ar": "ويستحب للإمام تخفيف الصلاة مع إتمامها،",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 701,
      "text_ar": "وتطويل الركعة الأولى أكثر من الثانية، ولا يستحب له انتظار داخل في الركوع",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 702,
      "text_ar": "في إحدى الروايتين.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 703,
      "text_ar": "وإذا استأذنت المرأة إلى المسجد، كره منعها. وبيتها خير لها.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 704,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 705,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 706,
      "text_ar": "في الإمامة",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 707,
      "text_ar": "السنة أن يؤم القوم أقرؤهم. ثم أفقههم، ثم أسنهم، ثم أقدمهم هجرة، ثم أشرفهم،",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 708,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 709,
      "text_ar": "ثم الأتقى، ثم من تقع له القرعة، وصاحب البيت، وإمام المسجد أحق",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 710,
      "text_ar": "بالإمامة إلا أن يكون بعضهم ذا سلطان. والحر أولى من العبد، والحاضر أولى",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 711,
      "text_ar": "من المسافر. والبصير أولى من الأعمى في أحد الوجهين",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 712,
      "text_ar": "وهل تصح إمامة",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 713,
      "text_ar": "الفاسق والأقلف؛ على روايتين. وفي إمامة أقطع اليدين وجهان",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 714,
      "text_ar": "ولا تصح",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 715,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 716,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 717,
      "text_ar": ". . . . . . . . . . . . . . . . . . . . . . . . . .",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 718,
      "text_ar": "الصلاة خلف كافر. ولا أخرس، ولا من به سلس البول، ولا عاجز عن الركوع",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 719,
      "text_ar": "والسجود والقعود.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 720,
      "text_ar": "ولا تصلح خلف عاجز عن القيام، إلا إمام الحي المرجو زوال",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 721,
      "text_ar": "علته، ويصلون وراءه جلوسا. فإن صلوا قياما صحت صلاتهم في أحد الوجهين،",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 722,
      "text_ar": "وإن ابتدأ بهم الصلاة قائما، ثم اعتل فجلس، أتموا خلفه قياما.",
      "text_en": "",
      "reference": "صلاة الضحى"
    },
    {
      "id": 723,
      "text_ar": "ولا تصح إمامة المرأة والخنثى للرجال ولا للخناثى.",
      "text_en": "",
      "reference": "صلاة الضحى"
    }
  ]
}