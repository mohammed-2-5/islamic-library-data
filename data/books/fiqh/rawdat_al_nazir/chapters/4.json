{
  "book_id": "rawdat_al_nazir",
  "chapter_id": 4,
  "title_ar": "4-",
  "title_en": "",
  "entries": [
    {
      "id": 178,
      "text_ar": "رسالة في مسألة العلو.",
      "text_en": "",
      "reference": "5-"
    },
    {
      "id": 179,
      "text_ar": "مسألة في تحريم النظر في كتب أهل الكتاب.",
      "text_en": "",
      "reference": "6-"
    },
    {
      "id": 180,
      "text_ar": "كتاب القدر.",
      "text_en": "",
      "reference": "7-"
    },
    {
      "id": 181,
      "text_ar": "ثانيا- في أصول الفقه:",
      "text_en": "",
      "reference": "7-"
    },
    {
      "id": 182,
      "text_ar": "لم أجد -فيما اطلعت عليه- أن له في الأصول سوى \"روضة الناظر وجنة المناظر\" والذي سوف نتحدث عن منهج المصنف فيه إن شاء الله تعالى.",
      "text_en": "",
      "reference": "7-"
    },
    {
      "id": 183,
      "text_ar": "ثالثا- في الفقه:",
      "text_en": "",
      "reference": "7-"
    },
    {
      "id": 184,
      "text_ar": "أما مؤلفات \"ابن قدامة\" في الفقه، فكثيرة جدا، منها ما وقفنا عليه:",
      "text_en": "",
      "reference": "7-"
    },
    {
      "id": 185,
      "text_ar": "المغني في شرح مختصر الخرقي.",
      "text_en": "",
      "reference": "1-"
    },
    {
      "id": 186,
      "text_ar": "المقنع.",
      "text_en": "",
      "reference": "2 -"
    },
    {
      "id": 187,
      "text_ar": "الكافي.",
      "text_en": "",
      "reference": "3 -"
    },
    {
      "id": 188,
      "text_ar": "عمدة الأحكام.",
      "text_en": "",
      "reference": "4 -"
    },
    {
      "id": 189,
      "text_ar": "مختصر الهداية لأبي الخطاب.",
      "text_en": "",
      "reference": "5 -"
    },
    {
      "id": 190,
      "text_ar": "رسالة في المذاهب الأربعة.",
      "text_en": "",
      "reference": "6 -"
    },
    {
      "id": 191,
      "text_ar": "فقه الإمام.",
      "text_en": "",
      "reference": "7 -"
    },
    {
      "id": 192,
      "text_ar": "فتاوى ومسائل منثورة.",
      "text_en": "",
      "reference": "8 -"
    },
    {
      "id": 193,
      "text_ar": "مقدمة في الفرائض.",
      "text_en": "",
      "reference": "9 -"
    },
    {
      "id": 194,
      "text_ar": "مناسك الحج.",
      "text_en": "",
      "reference": "10-"
    },
    {
      "id": 195,
      "text_ar": "رابعا- في الكتاب والسنة:",
      "text_en": "",
      "reference": "10-"
    },
    {
      "id": 196,
      "text_ar": "البرهان في مسألة القرآن.",
      "text_en": "",
      "reference": "1-"
    },
    {
      "id": 197,
      "text_ar": "قنعة الأريب في الغريب.",
      "text_en": "",
      "reference": "2-"
    },
    {
      "id": 198,
      "text_ar": "مختصر علل الحديث؛ لأبي بكر أحمد بن محمد بن هارون الخلال المتوفى سنة \"311ه\".",
      "text_en": "",
      "reference": "3-"
    },
    {
      "id": 199,
      "text_ar": "مختصر في غريب الحديث.",
      "text_en": "",
      "reference": "4-"
    },
    {
      "id": 200,
      "text_ar": "جواب مسألة وردت من صرخد في القرآن.",
      "text_en": "",
      "reference": "5-"
    },
    {
      "id": 201,
      "text_ar": "خامسا- في الفضائل والأخلاق:",
      "text_en": "",
      "reference": "5-"
    },
    {
      "id": 202,
      "text_ar": "فضائل الصحابة.",
      "text_en": "",
      "reference": "1-"
    },
    {
      "id": 203,
      "text_ar": "فضائل العشرة المبشرين بالجنة.",
      "text_en": "",
      "reference": "2-"
    },
    {
      "id": 204,
      "text_ar": "فضائل عاشوراء.",
      "text_en": "",
      "reference": "3-"
    },
    {
      "id": 205,
      "text_ar": "كتاب التوابين.",
      "text_en": "",
      "reference": "4-"
    },
    {
      "id": 206,
      "text_ar": "كتاب الرقة والبكاء.",
      "text_en": "",
      "reference": "5-"
    },
    {
      "id": 207,
      "text_ar": "كتاب الزهد.",
      "text_en": "",
      "reference": "6-"
    },
    {
      "id": 208,
      "text_ar": "ذم الوسواس.",
      "text_en": "",
      "reference": "7-"
    },
    {
      "id": 209,
      "text_ar": "كتاب المتحابين في الله.",
      "text_en": "",
      "reference": "8-"
    },
    {
      "id": 210,
      "text_ar": "سادسا- في التاريخ والأنساب:",
      "text_en": "",
      "reference": "8-"
    },
    {
      "id": 211,
      "text_ar": "الاستبصار في نسب الأنصار.",
      "text_en": "",
      "reference": "1-"
    },
    {
      "id": 212,
      "text_ar": "التبيين في نسب القرشيين.",
      "text_en": "",
      "reference": "2-"
    },
    {
      "id": 213,
      "text_ar": "مشيخة شيوخه.",
      "text_en": "",
      "reference": "3-"
    },
    {
      "id": 214,
      "text_ar": "مشيخة أخرى.",
      "text_en": "",
      "reference": "4-"
    },
    {
      "id": 215,
      "text_ar": "هذا بالإضافة إلى رسائل أخرى في موضوعات متفرقة1.",
      "text_en": "",
      "reference": "4-"
    },
    {
      "id": 216,
      "text_ar": "منهج ابن قدامة:",
      "text_en": "",
      "reference": "4-"
    },
    {
      "id": 217,
      "text_ar": "في كتابه: روضة الناظر وجنة المناظر",
      "text_en": "",
      "reference": "4-"
    },
    {
      "id": 218,
      "text_ar": "من المعروف أن \"ابن قدامة\" حنبلي المذهب، والحنابلة -بصفة عامة- يسيرون على منهج المتكلمين الذي يعنون بتأسيس القواعد وإقامة الأدلة عليها.",
      "text_en": "",
      "reference": "1-"
    },
    {
      "id": 219,
      "text_ar": "والمؤلف سلك نفس المسلك، فيذكر مذاهب العلماء في المسألة مقرونة بأدلتها، ثم يذكر ما يراه راجحا، مؤيدا بالبرهان والدليل، ثم يناقش أدلة المخالفين ويبين وجه الخطأ فيما قالوه.",
      "text_en": "",
      "reference": "1-"
    },
    {
      "id": 220,
      "text_ar": "وقد بين -رحمه الله تعالى- منهجه هذا في مقدمة كتابه فقال:",
      "text_en": "",
      "reference": "1-"
    },
    {
      "id": 221,
      "text_ar": "\"أما بعد: فهذا كتاب نذكر فيه أصول الفقه، والاختلاف فيه، ودليل كل قول، على وجه الاختصار، والاقتصار من كل قول على المختار، ونبين من ذلك ما نرتضيه، ونجيب على من خالفنا فيه\".",
      "text_en": "",
      "reference": "1-"
    },
    {
      "id": 222,
      "text_ar": "فهو بذلك يريد أن يجعل كتابه في \"أصول الفقه المقارن\" كما فعل ذلك في كتابه \"المغني\" في الفقه، فهو موضوع أساسا على مذهب الإمام أحمد بن حنبل -رحمه الله تعالى- لكنه أضاف إليه أقوال بعض المذاهب الأخرى، مقرونة -أحيانا- بأدلتها، ثم يناقش هذه الأدلة ويبين الراجح في النهاية بقوله: \"ولنا\".",
      "text_en": "",
      "reference": "1-"
    },
    {
      "id": 223,
      "text_ar": "ولذلك يعتبره العلماء من أهم المراجع في الفقه المقارن.",
      "text_en": "",
      "reference": "1-"
    },
    {
      "id": 224,
      "text_ar": "والمؤلف سلك في كتابه \"الروضة\" مسلك الإمام الغزالي في كتاب \"المستصفى من علم الأصول\" في الجملة، حتى إنه تبعه في إضافة المقدمة المنطقية إلى كتابه، والتي كانت مثار انتقاد له من بعض العلماء، حتى قيل: إنه حذفها فيما بعد من بعض النسخ.",
      "text_en": "",
      "reference": "2-"
    },
    {
      "id": 225,
      "text_ar": "كما تبعه في ترتيب أدلة الأحكام، فجعلها على هذا النحو: كتاب الله -تعالى-، ثم سنة رسوله -صلى الله عليه وسلم-، ثم الإجماع، ثم دليل العقل المبقي على النفي الأصلي، ثم في الأدلة المختلف فيها، وأخر القياس وجعله في باب: ما يقتبس من الألفاظ، مخالفا ما عليه جمهور العلماء من المذاهب الأربعة، حيث يجعلون القياس من الأدلة الأربعة المتفق عليها: الكتاب، السنة، الإجماع، القياس.",
      "text_en": "",
      "reference": "2-"
    },
    {
      "id": 226,
      "text_ar": "جاء في شرح الكوكب المنير1: \"أدلة الفقه المتفق عليها -على ما في بعضها من خلاف ضعيف جدا- أربعة:",
      "text_en": "",
      "reference": "2-"
    },
    {
      "id": 227,
      "text_ar": "الأول: الكتاب، وهو القرآن، وهو الأصل.",
      "text_en": "",
      "reference": "2-"
    },
    {
      "id": 228,
      "text_ar": "والثاني: السنة",
      "text_en": "",
      "reference": "2-"
    }
  ]
}