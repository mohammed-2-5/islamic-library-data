{
  "book_id": "rawdat_al_nazir",
  "chapter_id": 71,
  "title_ar": "ثانيا: فهرس الأحاديث",
  "title_en": "",
  "entries": [
    {
      "id": 6703,
      "text_ar": "أ- آثار الصحابة -رضي الله عنهم:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6704,
      "text_ar": "أبو بكر الصديق:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6705,
      "text_ar": "\"أعطى الجدة السدس\" 1/ 314",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6706,
      "text_ar": "\"أقول فيها برأيي فإن يكن صوابا فمن الله، وإن يكن خطأ فمني ومن الشيطان\" 2/ 158",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6707,
      "text_ar": "\"إنما أسلموا لله وأجورهم عليه\" 2/ 159-349",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6708,
      "text_ar": "\"سوى بين الصحابة في العطاء\" 2/ 159",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6709,
      "text_ar": "عمر بن الخطاب:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6710,
      "text_ar": "\"أذكر الله امرءا سمع من رسول الله -صلى الله عليه وسلم- في الجنين\" 1/ 314",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6711,
      "text_ar": "\"اعرف الأشباه والأمثال وقس الأمور برأيك\" 2/ 159",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6712,
      "text_ar": "\"اكتب: هذا ما رآه عمر فإن يكن صوابا فمن الله، وإن يكن خطأ فمن عمر\" 2/ 359",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6713,
      "text_ar": "\"إني لا أتهمك، ولكني خشيت أن يتقول الناس عن رسول الله -صلى الله عليه وسلم\" 1/ 326",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6714,
      "text_ar": "\"إياكم وأصحاب الرأي فإنهم أعداء السنن\" 2/ 161",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6715,
      "text_ar": "\"رجع عمر إلى قول معاذ في ترك رجم المرأة\" 1/ 471",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6716,
      "text_ar": "\"رجع إلى حديث عبد الرحمن بن عوف في المجوس\" 1/ 316",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6717,
      "text_ar": "\"رد خبر فاطمة بنت قيس في السكنى والنفقة\" 1/ 595",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6718,
      "text_ar": "\"عجبت مما عجبت منه\" 2/ 118",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6719,
      "text_ar": "\"عجزت النساء أن يلدن مثل معاذ لولا معاذ لهلك عمر\" 1/ 471",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6720,
      "text_ar": "\"قدم عمر حديث حمل بن مالك في غرة الجنين\" 1/ 373",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6721,
      "text_ar": "\"كان يرى إعتاق أم الوالد\" 420",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6722,
      "text_ar": "\"كان لا يورث المرأة من دية زوجها حتى أخبره الضحاك أن رسول الله -صلى الله عليه وسلم- كتب إليه أن يورث امرأة أشيم الضبابي\" 1/ 315",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6723,
      "text_ar": "\"كان يفاضل بين ديات الأصابع، ويقسمها على قدر منافعها ثم رجع عن ذلك\" 1/ 374",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6724,
      "text_ar": "\"لم يقبل خبر أبي موسى في الاستئذان\" 1/ 323",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6725,
      "text_ar": "\"لو لم نسمع هذا لقضينا بغيره\" 1/ 315",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6726,
      "text_ar": "\"ما لم تجد في السنة فاجتهد رأيك\" 1/ 399",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6727,
      "text_ar": "\"لا أجعل من ترك داره وماله وهاجر إلى الله ورسوله كمن أسلم كرها\" 2/ 159",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6728,
      "text_ar": "\"لا ندع كتاب ربنا وسنة نبينا لقول امرأة لا ندري أصدقت أم كذبت\" 1/ 264",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6729,
      "text_ar": "عثمان بن عفان:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6730,
      "text_ar": "\"اختلاف عثمان وعلى في الجمع بين الأختين بملك اليمين\" 2/ 20",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6731,
      "text_ar": "\"أحلتهما آية وحرمتهما آية\" 2/ 20",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6732,
      "text_ar": "\"أخذ بخبر فريعة بنت مالك في السكنى\" 316",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6733,
      "text_ar": "\"إن نتبغ رأيك فرأي رشيد، وإن نتبع رأي من قبلك فنعم ذو الرأي كان\" 2/ 160",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6734,
      "text_ar": "\"لا شيء عليك إنما أنت مؤدب\" 2/ 356",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6735,
      "text_ar": "على بن أبي طالب:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6736,
      "text_ar": "\"اجتمع رأي ورأي عمر في أمهات الأولاد أن لا يبعن وأنا الآن أرى بيعهن\" 2/ 160",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6737,
      "text_ar": "\"إذا سكر هذي وإذا هذي افترى، فحدوه حد المفتري\" 2/ 160",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6738,
      "text_ar": "\"إن يكونا قد اجتهدا فقد أخطآ، وإن يكونا ما اجتهدا فقدغشاك، عليك الدية\" 2/ 356",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6739,
      "text_ar": "\"رد خبر معقل بن سنان الأشجعي في بروع بنت واشق\" 1/ 323",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6740,
      "text_ar": "\"ضرب في الخمر أربعين\" 1/ 420",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6741,
      "text_ar": "\"كان لا يقبل الخبر حتى يستحلف\" 1/ 317",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6742,
      "text_ar": "\"كنت إذا سمعت من النبي -صلى الله عليه وسلم- حديثا نفعني الله بما شاء منه أن ينفعني، وإذا حدثني غيره استحلفته\" 1/ 317",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6743,
      "text_ar": "\"لو كان الدين بالرأي لكان أسفل الخف أولى بالمسح من أعلاه\" 2/ 162",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6744,
      "text_ar": "أنس بن مالك:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6745,
      "text_ar": "\"سلوا مولانا الحسن فإنه غاب وحضرنا، وحفظ ونسينا\" 1/ 400",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6746,
      "text_ar": "\"كنت أسقى أبا طلحة وأبا عبيدة وأبي بن كعب شرابا من فضيخ\" 1/ 318",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6747,
      "text_ar": "البراء بن عازب:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6748,
      "text_ar": "\"ما كل ما حدثناكم به عن رسول الله -صلى الله عليه وسلم- سمعناه منه غير أنا لا نكذب\" 1/ 364",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6749,
      "text_ar": "زيد بن سهل-أبو طلحة- وأصحابه:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6750,
      "text_ar": "\"قبلوا خبر الواحد في تحريم الخمر من غير ماجعة\" 1/ 357",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6751,
      "text_ar": "عائشة - أم المؤمنين:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6752,
      "text_ar": "\"أبلغي زيد بن أرقم أنه قد أبطل جهاده مع رسول الله -صلى الله عليه وسلم- إلا أن يتوب\" 2/ 359",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6753,
      "text_ar": "\"أنكرت على زيد بن أرقم تعامله بمسألة العينة\" 1/ 408",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6754,
      "text_ar": "\"إنما مثلك مثل الفروج سمع الديكة تصيح فصاح لصياحها\" 1/ 398",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6755,
      "text_ar": "\"ردت حديث ابن عمر في تعذيب الميت ببكاء أهله عليه\" 1/ 325",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6756,
      "text_ar": "\"كانوا لا يقطعون في الشيء التافه\" 1/ 286",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6757,
      "text_ar": "عبد الرحمن بن صخر- أبو هريرة:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6758,
      "text_ar": "\"أنا مع ابن أخي\" 1/ 401",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6759,
      "text_ar": "عبد الله بن عباس:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6760,
      "text_ar": "\"ألا يتقي الله زيد؟! يجعل ابن الابن ابنا ولا يجعل أب الأب أبا! \" 2/ 359",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6761,
      "text_ar": "\"إن الله لم يجعل لأحد أن يحكم برأيه\" 2/ 162",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6762,
      "text_ar": "\"إياكم والمقاييس؛ فما عبدت الشمس إلا بالمقاييس\" 2/ 163",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6763,
      "text_ar": "\"سل فلانة الأنصارية\" 1/ 320",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6764,
      "text_ar": "\"كان رجلا مهيبا فهبته\" 1/ 435",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6765,
      "text_ar": "\"كنا نأخذ بالأحدث فالأحدث من أمر رسول الله -صلى الله عليه وسلم-\" 2/ 65",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6766,
      "text_ar": "\"لم حجبت الأم بالاثنين من الإخوة؟ \" 2/ 33",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6767,
      "text_ar": "\"من شاء باهلته في العول\" 2/ 359",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6768,
      "text_ar": "عبد الله بن عمر:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6769,
      "text_ar": "\"رجع إلى حديث رافع في المخابرة\" 1/ 320-2/ 43",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6770,
      "text_ar": "\"رد خبر أبي هريرة في أن من صلى على الميت فله قيراطان\" 2/ 392",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6771,
      "text_ar": "عبد الله بن مسعود:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6772,
      "text_ar": "\"إن حكمتم بالرأي أحللتم كثيرا مما حرمه الله\" 2/ 162",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6773,
      "text_ar": "\"ذروني من أرأيت وأرأيت\" 2/ 163",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6774,
      "text_ar": "\"قراؤكم وصلحاؤكم يذهبون ويتخذ الناس رؤساء جهالا\" 2/ 162",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6775,
      "text_ar": "عثمان بن مظعون:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6776,
      "text_ar": "\"كذبت فإن نعيم الجنة لا يزول\" 2/ 21",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6777,
      "text_ar": "ب- آثار التابعين -رضي الله عنهم:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6778,
      "text_ar": "إبراهيم النخعي:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6779,
      "text_ar": "\"إذا رويت عن عبد الله وأسندت فقد حدثني واحد، وإذا أرسلت فقد حدثني جماعة عنه\" 1/ 367",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6780,
      "text_ar": "الحسن البصري:",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    },
    {
      "id": 6781,
      "text_ar": "\"إذا أمرت بمعروف فكن من آخذ الناس به، وإذا نهيت عن منكر فكن من أترك الناس له وإلا هلكت\" 2/ 55",
      "text_en": "",
      "reference": "ثالثا: فهرس الآثار"
    }
  ]
}