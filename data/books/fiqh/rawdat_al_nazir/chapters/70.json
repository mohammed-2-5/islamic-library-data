{
  "book_id": "rawdat_al_nazir",
  "chapter_id": 70,
  "title_ar": "ثانيا: فهرس الأحاديث.",
  "title_en": "",
  "entries": [
    {
      "id": 6480,
      "text_ar": "حرف الألف:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6481,
      "text_ar": "\"الأئمة من قريش\" 1/ 423",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6482,
      "text_ar": "\"الاثنان فما فوقهما جماعة\" 2/ 32",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6483,
      "text_ar": "\"اجتهدا فإن أصبتما فلكما عشر حسنات\" 2/ 340",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6484,
      "text_ar": "\"ادرأوا الحدود بالشبهات\" 1/ 370",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6485,
      "text_ar": "\"إذا اجتهد الحاكم فأصاب فله أجران\" 2/ 358",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6486,
      "text_ar": "\"إذا توضأ أحدكم فأحسن وضوءه ثم خرج إلى المسجد فلا يشبك بين أصابعه\" 1/ 138",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6487,
      "text_ar": "\"إذا حاصرتم حصنا أو مدينة فطلبوا منكم أن تنزلوهم على حكم الله فلا تنزلوهم\" 2/ 355",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6488,
      "text_ar": "\"إذا حكم الحاكم فاجتهد فأصاب فله أجران\" 2/ 172",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6489,
      "text_ar": "\"إذا قال الإمام: {ولا الضالين} فقولوا آمين\" 1/ 545",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6490,
      "text_ar": "\"إذا لم تستح فاصنع ما شئت\" 1/ 547",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6491,
      "text_ar": "\"إذا مس الختان الختان وجب الغسل\" 1/ 318",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6492,
      "text_ar": "\"أرأيت لو تمضمضت؟ \" قاله لعمر 2/ 39-174",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6493,
      "text_ar": "\"أرأيت لو كان على أبيك دين فقضيته؟! \" 2/ 172",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6494,
      "text_ar": "\"أرأيت لو كان على أمك دين فقضيته أكان ينفعها\" 2/ 201",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6495,
      "text_ar": "\"أرخص رسول الله -صلى الله عليه وسلم- في السلم ووضع الجوائح\" 2/ 43",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6496,
      "text_ar": "\"أصحابي كالنجوم بأيهم اقتديتم اهتديتم\" 1/ 468",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6497,
      "text_ar": "\"أعتق رقبة\" قال لأعرابي الذي جامع امرأته في نهار رمضان 2/ 148",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6498,
      "text_ar": "\"أما علمت أن الإسلام يهدم ما كان قبله\" 1/ 165",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6499,
      "text_ar": "\"أمرت أن أقاتل الناس حتى يقولوا لا إله إلا الله\" 2/ 19",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6500,
      "text_ar": "\"أمسك عليك لسانك\" 1/ 544",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6501,
      "text_ar": "\"أمسك منهن أربعا وفارق سواهن\" 1/ 511",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6502,
      "text_ar": "\"إن أنت قضيت بينهما فأصبت فلك عشر حسنات\" 2/ 339",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6503,
      "text_ar": "\"إن أعظم المسلمين في المسلمين جرما من سأل عن شيء لم يحرم على الناس فحرم من أجل مسألته\" 1/ 135-136",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6504,
      "text_ar": "\"إن شئت فتوضأ وإن شئت فلا تتوضأ\" 1/ 562",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6505,
      "text_ar": "\"إنا معاشر الأنبياء لا نورث\" 2/ 69",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6506,
      "text_ar": "\"إنا وبنو عبد المطلب لم نفترق في جاهلية ولا إسلام\" 1/ 537",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6507,
      "text_ar": "\"إنكم لتختصمون إلي ولعل بعضكم أن يكون ألحن بحجته من بعض\" 2/ 354",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6508,
      "text_ar": "\"إن الله اختارني واختار لي أصحابا وأنصارا\" 1/ 346",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6509,
      "text_ar": "\"إن الله عفا لأمتي عما حدثت به نفسها ما لم تتكلم أو تعمل\" 1/ 544",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6510,
      "text_ar": "\"إن الله فرض عليكم صيامه\" 1/ 586",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6511,
      "text_ar": "\"إن الله قد أعطى كل ذي حق حقه فلا وصية لوارث\" 1/ 262",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6512,
      "text_ar": "\"إن الله لا يقبض العلم انتزاعا من الناس ولكن بقبض العلماء\" 1/ 391",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6513,
      "text_ar": "\"إنما أسهو لأسن\" 1/ 593",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6514,
      "text_ar": "\"إنما أنا شافع\" 1/ 555",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6515,
      "text_ar": "\"إنما الأعمال بالنيات\" 1/ 247-2/ 128",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6516,
      "text_ar": "\"إنما جعل الأستئذان من أجل البصر\" 2/ 193",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6517,
      "text_ar": "\"إنما الربا في النسيئة\" 1/ 281",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6518,
      "text_ar": "\"إنما نهيتكم من أجل الدافة\" 2/ 193",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6519,
      "text_ar": "\"إنما الولاء لمن أعتق\" 2/ 127",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6520,
      "text_ar": "\"أن النبي -صلى الله عليه وسلم- أعطى الجدة السدس\" 1/ 314",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6521,
      "text_ar": "\"أن النبي -صلى الله عليه وسلم- رخص في تعجيل الزكاة\" 1/ 186",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6522,
      "text_ar": "\"أن النبي -صلى الله عليه وسلم- قبل شهادة الأعرابي برؤية الهلال\" 1/ 335",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6523,
      "text_ar": "\"أن النبي -صلى الله عليه وسلم- قضى بشاهد ويمين\" 1/ 358",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6524,
      "text_ar": "\"أن النبي -صلى الله عليه وسلم- كتب إلى الضحاك أن يورث امرأة أشيم الضبابي من دية زوجها\" 1/ 315",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6525,
      "text_ar": "\"إنها رجس\" قاله عن الروثة 2/ 194",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6526,
      "text_ar": "\"إنها ليست بنجس إنها من الطوافين عليكم والطوافات\" 2/ 146-194",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6527,
      "text_ar": "\"إني أقضي بينكم الرأي فيما لم ينزل به وحي\" 2/ 174",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6528,
      "text_ar": "\"إني لبدت رأسي وقلدت هديي فلا أحل حتى أنحر\" 1/ 593",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6529,
      "text_ar": "\"أيما امرأة نكحت نفسها بغير إذن وليها فنكاحها باطل\" 1/ 513-2/ 12",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6530,
      "text_ar": "\"أيما رجل أفلس فصاحب المتاع أحق بمتاعه\" 2/ 183",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6531,
      "text_ar": "\"الأيم أحق بنفسها من وليها البكر تستأذن\" 2/ 134",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6532,
      "text_ar": "حرف الباء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6533,
      "text_ar": "\"بدأ الإسلام غريبا وسيعود غريبا فطوبى للغرباء\" 1/ 404",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6534,
      "text_ar": "\"بعثت إلى الأحمر والأسود وكل نبي بعث إلى قومه\" 1/ 459",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6535,
      "text_ar": "\"بل هو رأي رأيته لكم\" 2/ 345",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6536,
      "text_ar": "\"بم تحكم؟ \" قاله لمعاذ حين بعثه إلى اليمن 1/ 460",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6537,
      "text_ar": "\"بين المراد بالصلاة صلاة جبريل به -صلى الله عليه وسلم- في اليومين\" 1/ 537",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6538,
      "text_ar": "\"البينة على من ادعى واليمين على من أنكر\"1/ 454",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6539,
      "text_ar": "حرف التاء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6540,
      "text_ar": "\"تبيين النبي -صلى الله عليه وسلم- الصلاة والحج بفعله\" 1/ 531",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6541,
      "text_ar": "\"تحريمها التكبير وتحليها التسليم\" 2/ 129",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6542,
      "text_ar": "\"تخصيص أبي بردة بجذعة من المعز\" 1/ 596",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6543,
      "text_ar": "\"تخصيص خزيمة بشهادته وحده\" 2/ 285",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6544,
      "text_ar": "\"تزوج النبي -صلى الله عليه وسلم- ميمونة وهو حلال وكنت السفير بينهما\" 2/ 394",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6545,
      "text_ar": "\"تزوجني النبي -صلى الله عليه وسلم- ونحن حلالان\" 2/ 393",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6546,
      "text_ar": "\"توضؤوا من لحوم الإبل ولا تتوضؤوا من لحوم الغنم\" 1/ 562",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6547,
      "text_ar": "حرف الثاء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6548,
      "text_ar": "\"ثلاث لا يغل عليهم قلب المسلم إخلاص العمل لله والمناصحة لولاه الأمر ولزوم جماعة المسلمين\" 1/ 385",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6549,
      "text_ar": "\"الثيب أحق بنفسها من وليها\" 2/ 134",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6550,
      "text_ar": "حرف الحاء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6551,
      "text_ar": "\"حتى يذوق عسيلتها\" 2/ 69",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6552,
      "text_ar": "\"حديث حمل بن مالك في دية الجنين\" 1/ 314",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6553,
      "text_ar": "\"حديث الخثعمية\" 2/ 173",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6554,
      "text_ar": "\"حديث رافع في المخابرة\" 1/ 285",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6555,
      "text_ar": "\"حديث فاطمة بنت قيس في النفقة والسكنى للمبتوتة\" 1/ 595",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6556,
      "text_ar": "\"حديث معاذ في الاجتهاد\" 1/ 595",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6557,
      "text_ar": "\"حرمت الخمر لعينها\" 1/ 373",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6558,
      "text_ar": "\"الحلال ما أحل الله في كتابه، والحرام ما حرم الله في كتابه، وما سكت عنه فهو مما عفا عنه\" 1/ 135",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6559,
      "text_ar": "حرف الخاء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6560,
      "text_ar": "\"خبر أبي موسى في الاستئذان\" 1/ 323",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6561,
      "text_ar": "\"خبر دية الجنين\" 1/ 314",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6562,
      "text_ar": "\"خبر ذي اليدين\" 1/ 325",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6563,
      "text_ar": "\"خبر رافع بن خديج\" 1/ 285",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6564,
      "text_ar": "\"خبر زيادة التغريب على الجلد في الحد\" 1/ 343",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6565,
      "text_ar": "\"خبر المغيرة في ميراث الجدة\" 1/ 314",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6566,
      "text_ar": "\"خذوا عني مناسككم\" 1/ 531-538",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6567,
      "text_ar": "\"خطابي للواحد خطاب للجماعة\" 1/ 594",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6568,
      "text_ar": "\"خير الناس قرني\" 1/ 346",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6569,
      "text_ar": "حرف الدال:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6570,
      "text_ar": "\"دعي الصلاة أيام أقرائك\" 1/ 145-612",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6571,
      "text_ar": "حرف الراء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6572,
      "text_ar": "\"رب حامل فقه غير فقيه، ورب حامل فقه إلى من هو أفقه منه\" 1/ 340",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6573,
      "text_ar": "\"رخص في العرايا\" 2/ 278",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6574,
      "text_ar": "\"رضخ يهودي رأس جارية فأمر به رسول الله -صلى الله عليه وسلم- أن يرض رأسه بين حجرين\" 2/ 198",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6575,
      "text_ar": "\"رفع عن أمتي الخطأ والنسيان وما استكرهوا عليه\" 1/ 152-524",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6576,
      "text_ar": "\"رفع القلم عن ثلاثة عن الصبي حتى يبلغ ... \" 1/ 599",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6577,
      "text_ar": "حرف السين:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6578,
      "text_ar": "\"سقوط طواف الوداع عن الحائض\" 1/ 595",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6579,
      "text_ar": "\"سنوا بهم سنة أهل الكتاب\" 1/ 316-556",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6580,
      "text_ar": "\"سها رسول الله -صلى الله عليه وسلم- فسجد\" 2/ 198",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6581,
      "text_ar": "حرف الشين:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6582,
      "text_ar": "\"الشفعة فيما لم يقسم\" 2/ 129",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6583,
      "text_ar": "\"الشهر هكذا وهكذا وهكذا\" 1/ 530",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6584,
      "text_ar": "\"الشيطان مع الواحد وهو من الاثنين أبعد\" 1/ 403",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6585,
      "text_ar": "حرف الصاد:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6586,
      "text_ar": "\"صحة صوم من أصبح جنبا\" 1/ 590",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6587,
      "text_ar": "\"صدقة تصدق الله بها عليكم فاقبلوا صدقته\" 2/ 118",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6588,
      "text_ar": "\"صلوا كما رأيتموني أصلي\" 1/ 531",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6589,
      "text_ar": "\"صوب النبي -صلى الله عليه وسلم- معاذا على الاجتهاد\" 1/ 372",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6590,
      "text_ar": "حرف الطاء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6591,
      "text_ar": "\"الطواف بالبيت صلاة إلا أنكم تتكلمون فيه\" 1/ 247",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6592,
      "text_ar": "حرف العين:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6593,
      "text_ar": "\"العائد في هبته كالعائد في قيئه\" 1/ 193",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6594,
      "text_ar": "\"عدم ثبوت حكم الإحرام في حق من بعث هديه وأقام في أهله\" 1/ 590",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6595,
      "text_ar": "\"عليكم بسنتي وسنة الخلفاء الراشدين\" 1/ 467",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6596,
      "text_ar": "حرف الغين:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6597,
      "text_ar": "\"الغسل من التقاء الختانين من غير إنزال\" 1/ 590",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6598,
      "text_ar": "حرف الفاء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6599,
      "text_ar": "\"فلا إذا\" 2/ 201",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6600,
      "text_ar": "\"فلها المهر بما استحل من فرجها\" 1/ 513",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6601,
      "text_ar": "\"فليغسله سبعا\" 1/ 556",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6602,
      "text_ar": "\"في أربعين شاة شاة\" 1/ 538-2/ 72",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6603,
      "text_ar": "\"في سائمة الغنم الزكاة\" 1/ 455-2/ 73-114-132",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6604,
      "text_ar": "\"في كل أصبع عشر من الإبل\" 1/ 374",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6605,
      "text_ar": "\"فيما سقت السماء العشر\" 2/ 63",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6606,
      "text_ar": "حرف القاء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6607,
      "text_ar": "\"قد جعل الله لهن سبيلا: البكر بالبكر جلد مائة وتغريب عام، والثيب بالثيب الجلد والرجم\" 1/ 260",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6608,
      "text_ar": "\" القرآن ينسخ حديثي، وحديثي لا ينسخ القرآن\" 1/ 261",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6609,
      "text_ar": "\"قضي بالشفعة فيما لم يقسم\" 2/ 42",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6610,
      "text_ar": "\"قضى رسول الله -صلى الله عليه وسلم- بالقصاص بالسن، وقال: كتاب الله القصاص\" 1/ 463",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6611,
      "text_ar": "\"قضى النبي -صلى الله عليه وسلم- في الجنين بغرة\" 1/ 315",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6612,
      "text_ar": "حرف الكاف:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6613,
      "text_ar": "\"كان رسول الله صلى الله عليه وسلم- يأمرني فأتزر فيباشرني\" 2/ 73",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6614,
      "text_ar": "\"كتاب الله القصاص\" 1/ 463",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6615,
      "text_ar": "\"كتابة النبي -صلى الله عليه وسلم- إلى عماله في الصدقات\" 1/ 529",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6616,
      "text_ar": "\"الكلب الأسود شيطان\" 2/ 120",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6617,
      "text_ar": "\"كنا نخابر أربعين سنة\" 1/ 285",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6618,
      "text_ar": "\"كنا نفاضل على عهد رسول الله -صلى الله عليه وسلم- فنقول: أبو بكر وعمر وعثمان\" 1/ 285",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6619,
      "text_ar": "\"كنا نحيض على عهد رسول الله فنؤمر بقضاء الصوم دون الصلاة\" 1/ 187",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6620,
      "text_ar": "\"كنت رخصت لكم في جلود الميتة فلا تنتفعوا\" 1/ 270",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6621,
      "text_ar": "\"كنت نهيتكم عن زيارة القبور فزوروها\" 1/ 270",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6622,
      "text_ar": "\"كنت نهيتكم عن زيارة القبور فزوروها، ونهيتكم عن ادخار لحوم الأضاحي ... \" 1/ 561",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6623,
      "text_ar": "حرف اللام:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6624,
      "text_ar": "\"للأبد ولو قلت لعامنا لوجب\" 2/ 344",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6625,
      "text_ar": "\"لم يقبل النبي -صلى الله عليه وسلم- خبر ذي اليدين\" 1/ 322",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6626,
      "text_ar": "\"لم يكن الله ليجمع هذه الأمة على خطأ\" 1/ 383",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6627,
      "text_ar": "\"لو كان على أمها دين فقضته ألم يكن يجزئ عنها\" 1/ 580",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6628,
      "text_ar": "\"لولا أن أشق على أمتي لأمرتهم بالسواك عند كل صلاة\" 1/ 125-128",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6629,
      "text_ar": "\"ليس فيما دون خمسة أوسق صدقة\" 1/ 538",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6630,
      "text_ar": "\"ليس الوضوء من القطرة والقطرتين\" 2/ 135",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6631,
      "text_ar": "حرف الميم:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6632,
      "text_ar": "\"ما رآه المسلمون حسنا فهو عند الله حسن ... \" 1/ 384-474",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6633,
      "text_ar": "\"ما من عبد يذنب فيتوضأ ثم يصلي ركعتين ويستغفر الله إلا غفر الله له\" 1/ 317",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6634,
      "text_ar": "\"ما هذا؟! ألم آت بها بيضاء؟! نقية لو أدركني موسى ما وسعه إلا اتباعي\" 1/ 460",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6635,
      "text_ar": "\"مروهم بالصلاة لسبع\" 1/ 582",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6636,
      "text_ar": "\"من أحيا أرضا ميتة فهي له\" 2/ 197",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6637,
      "text_ar": "\"من اتخذ كلبا -إلا كلب ماشية أو صيد- نقص من أجره كل يوم قيراطان\" 2/ 199",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6638,
      "text_ar": "\"من أراد بحبوحة الجنة فليلزم الجماعة\" 1/ 386",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6639,
      "text_ar": "\"من أصبح جنبا فلا صوم له\" 1/ 280",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6640,
      "text_ar": "\"من أعتق شركا له في عبد قوم عليه الباقي\" 2/ 183",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6641,
      "text_ar": "\"من باع نخلا بعد أن تؤبر فثمرته للبائع\" 2/ 80-197",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6642,
      "text_ar": "\"من دخل دار أبي سفيان فهو آمن، ومن أغلق عليه بابه فهو آمن\" 2/ 17",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6643,
      "text_ar": "\"من شذ شذ في النار\" 1/ 386",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6644,
      "text_ar": "\"من شهد جنازة\" 2/ 392",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6645,
      "text_ar": "\"من عمل عملا ليس عليه أمرنا فهو رد\" 1/ 608",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6646,
      "text_ar": "\"من فارق الجماعة شبرا فقد خلع ربقة الإسلام من عنقه\" 1/ 384",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6647,
      "text_ar": "\"من فارق الجماعة مات ميتة جاهلية\" 1/ 385",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6648,
      "text_ar": "\"من مس ذكره فليتوضأ\" 2/ 198",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6649,
      "text_ar": "\"من نام عن صلاة أو نسيها فليصلها إذا ذكرها\" 1/ 464-556-2/ 80",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6650,
      "text_ar": "حرف النون:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6651,
      "text_ar": "\"نحن معاشر الأنبياء لا نورث، ما تركناه صدقة\" 2/ 16",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6652,
      "text_ar": "\"نضر الله امرءا سمع مقالتي فأداها كما سمعها فرب مبلغ أوعى من سامع\" 1/ 279-361",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6653,
      "text_ar": "\"نكحها وهو محرم\" أي: ميمونة 2/ 394",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6654,
      "text_ar": "\"نهى عن بيع الثمر حتى يبدو صلاحه\" 2/ 43",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6655,
      "text_ar": "\"نهى رسول الله -صلى الله عليه وسلم- عن المزابنة\" 2/ 42",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6656,
      "text_ar": "\"نهى عن المنابزة والملامسة\" 1/ 612",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6657,
      "text_ar": "\"نهى عن المزابنة والمحاقلة والمخابرة\" 1/ 612-2/ 43",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6658,
      "text_ar": "\"نهى عن الصلاة في الأوقات الخمسة\" 1/ 145",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6659,
      "text_ar": "\"نهى عن الصلاة في المقبرة وقارعة الطريق والأماكن السبعة\" 1/ 145",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6660,
      "text_ar": "\"نهيت عن قتل النساء\" 2/ 81",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6661,
      "text_ar": "\"نهيتكم عن ادخار لحوم الأضاحي فوق ثلاث\" 2/ 194",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6662,
      "text_ar": "حرف الهاء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6663,
      "text_ar": "\"هو الطهور ماؤه\" 2/ 36",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6664,
      "text_ar": "حرف الواو:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6665,
      "text_ar": "\"وأنا تدركني الصلاة وأنا جنب\" 1/ 588",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6666,
      "text_ar": "\"وجوب الوضوء من ملامسة المرأة\" 1/ 590",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6667,
      "text_ar": "\"والله إني لأرجو أن أكون أخشاكم لله وأعلمكم بما أتقى\" 1/ 589",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6668,
      "text_ar": "\"والله لأغزون قريشا\" 1/ 570",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6669,
      "text_ar": "\"ومالي لا أغضب وأنا آمر بالأمر فلا أتبع\" 1/ 554",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6670,
      "text_ar": "حرف الباء:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6671,
      "text_ar": "\"يجزئك ولا يجزئ عن أحد بعدك\" 1/ 587",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6672,
      "text_ar": "\"يقطع الصلاة الكلب الأسود\" 2/ 119",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6673,
      "text_ar": "حرف اللام ألف:",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6674,
      "text_ar": "\"لا تبيعوا البر بالبر إلا سواء بسواء\" 2/ 76",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6675,
      "text_ar": "\"لا تبيعوا الذهب بالذهب إلا مثلا بمثل\" 1/ 609",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6676,
      "text_ar": "\"لا تجتمع أمتي على خطأ\" 1/ 383-396",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6677,
      "text_ar": "\"لا تجتمع أمتي على ضلالة\" 1/ 383",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6678,
      "text_ar": "\"لا تحرم المصة ولا المصتان\" 2/ 135",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6679,
      "text_ar": "\" لا تزال طائفة من أمتي على الحق لا يضرهم من خذلهم 1/ 386-428",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6680,
      "text_ar": "\"لا تقربوه طيبا فإنه يبعث يوم القيامة ملبيا\" 2/ 195",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6681,
      "text_ar": "\"لا تقلدوها الأوتار\" 2/ 380",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6682,
      "text_ar": "\"لا تكلفوهم ما لا يطيقون\" 1/ 172",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6683,
      "text_ar": "\"لا تلبسوا الحرير\" 1/ 144",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6684,
      "text_ar": "\"لا تنكح المرأة على عمتها ولا على خالتها\" 2/ 17-68-195",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6685,
      "text_ar": "\"لا زكاة في الحلي\" 1/ 454",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6686,
      "text_ar": "\"لا زكاة فيما دون خمسة أوسق\" 2/ 63",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6687,
      "text_ar": "\"لا صلاة إلا بطهور\" 1/ 521",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6688,
      "text_ar": "\"لا صلاة بعد العصر حتى تغرب الشمس\" 2/ 81",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6689,
      "text_ar": "\"لا صيام لمن لم يبيت الصيام من الليل\" 1/ 515",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6690,
      "text_ar": "\"لا عمل إلا بنية\" 1/ 523-2/ 110-128",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6691,
      "text_ar": "\"لا قطع إلا في ربع دينار\" 2/ 63",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6692,
      "text_ar": "\"لا نكاح إلا بولي\" 2/ 102-103",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6693,
      "text_ar": "\"لا نكاح إلا بولي مرشد وشاهدي عدل\" 2/ 103",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6694,
      "text_ar": "\"لا وصية لوارث\" 2/ 69",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6695,
      "text_ar": "\"لا يختلى خلاها\" 2/ 344",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6696,
      "text_ar": "\"لا يرث القاتل\" 2/ 17-2/ 69",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6697,
      "text_ar": "\"لا يرث المسلم الكافر ولا الكافر المسلم\" 2/ 68",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6698,
      "text_ar": "\"لا يقتل مسلم بكافر\" 1/ 82",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6699,
      "text_ar": "\"لا يقضي القاضي بين اثنين وهو غضبان\" 2/ 77-202",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6700,
      "text_ar": "\"لا يلبس القميص ولا السراويلات ولا البرانس\" 2/ 120",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6701,
      "text_ar": "\"لا ينكح المحرم ولا ينكح\" 1/ 610",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    },
    {
      "id": 6702,
      "text_ar": "\"لا يؤمن الرجل في سلطانه، ولا يجلس على تكرمته إلا بإذنه\" 2/ 94",
      "text_en": "",
      "reference": "ثانيا: فهرس الأحاديث"
    }
  ]
}