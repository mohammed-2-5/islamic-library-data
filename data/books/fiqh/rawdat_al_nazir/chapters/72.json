{
  "book_id": "rawdat_al_nazir",
  "chapter_id": 72,
  "title_ar": "ثالثا: فهرس الآثار",
  "title_en": "",
  "entries": [
    {
      "id": 6782,
      "text_ar": "حرف الباء:",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6783,
      "text_ar": "وإذا تكون كريهة أدعى لها وإذا يحاس الحيس يدعى جندب 1/ 240",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6784,
      "text_ar": "حرف الدال:",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6785,
      "text_ar": "قلدوها تمائما خوف واش وحاسد 2/ 380",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6786,
      "text_ar": "وقفت فيها أصيلانا اسائلها عيت جوابا وما بالربع من أحد 2/ 86",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6787,
      "text_ar": "إلا الأوراي لويا أبيتها والنوى كالحوض المظلومة الجلد 2/ 87",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6788,
      "text_ar": "يكلفه القوم ما نابهم وإن كان أصغرهم مولدا 1/ 153",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6789,
      "text_ar": "حرف الراء:",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6790,
      "text_ar": "لقد عثرت عثرة لا تنجبر سوف أليس بعدها أو أستمر",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6791,
      "text_ar": "أرفع من ذيلي ما كنت أجر وأجمع الرأي الشتيت المنتشر 2/ 355",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6792,
      "text_ar": "حرف السين:",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6793,
      "text_ar": "وبلدة ليس بها أنيس إلا اليعافير وإلا العيس 2/ 78",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6794,
      "text_ar": "حرف العين:",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6795,
      "text_ar": "وقلدوا أمركم لله دركم رحب الذراع بأمر الحرب مضطلعا 2/ 381",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6796,
      "text_ar": "حرف الفاء:",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6797,
      "text_ar": "نحن بما عندنا وأنت بما عندك راض والرأي مختلف 2/ 106",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6798,
      "text_ar": "ألا كل شيء ما خلا الله باطل وكل نعيم لا محالة زائل 2/ 21",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6799,
      "text_ar": "ألا أيها الليل الطويل ألا انجلي بصبح وما الإصباح منك بأمثل 1/ 547",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6800,
      "text_ar": "أنا الرجل الحامي الذمار وإنما يدافع عن أحسابهم أنا أو مثلي 2/ 128",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6801,
      "text_ar": "أهل الكلام وأهل الرأي قد جهلوا علم الحديث الذي ينجو به الرجل",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6802,
      "text_ar": "لو أنهم عرفوا الآثار ما انحرفوا عنها إلى غيرها لكنهم جهلوا 2/ 164",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6803,
      "text_ar": "وجيد كجيد الريم ليس بفاحش إذا هي نصته ولا بمعطل 1/ 507",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6804,
      "text_ar": "أدوا التي نقصت تسعين من مائة ثم ابعثوا حكما بالحق قوالا 2/ 91",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6805,
      "text_ar": "حرف الميم:",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6806,
      "text_ar": "أمرتك أمرا حازما فعصيتني فأصبحت مسلوب الإمارة نادما 1/ 557",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6807,
      "text_ar": "حرف النون:",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6808,
      "text_ar": "لا يسألون أخاهم حين يندبهم في النائبات على ما قال برهانا 1/ 124",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6809,
      "text_ar": "وما أدري إذا يممت أرضا أريد الخير أيهما يليني",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6810,
      "text_ar": "أألخير الذي أنا أبتغيه أم الشر الذي هو يبتغيني 2/ 106",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6811,
      "text_ar": "حرف الهاء:",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6812,
      "text_ar": "إذا قاسها الآسي النطاسي أدبرت غثيثتها أو زاد وهيا هزومها 2/ 140",
      "text_en": "",
      "reference": "رابعا: فهرس الأبيات الشعرية"
    },
    {
      "id": 6813,
      "text_ar": "حرف الألف:",
      "text_en": "",
      "reference": "خامسا: فهرس الأعلام"
    },
