{
  "book_id": "rawdat_al_nazir",
  "chapter_id": 68,
  "title_ar": "موضوعات الجزء الثاني:",
  "title_en": "",
  "entries": [
    {
      "id": 6071,
      "text_ar": "في التقليد.",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6072,
      "text_ar": "معنى التقليد في اللغة 380",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6073,
      "text_ar": "معنى التقليد عند الفقهاء 381",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6074,
      "text_ar": "ما لا يسوغ التقليد فيه 381",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6075,
      "text_ar": "ما يسوغ التقليد فيه وهو الفروع 382",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6076,
      "text_ar": "الأدلة على ذلك 383",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6077,
      "text_ar": "بطلان مذهب القدرية في وجوب النظر على العامة 383",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6078,
      "text_ar": "هل يجوز التقليد في أركان الإسلام ونحوها؟ 384",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6079,
      "text_ar": "فصل في من يستفتيه العامي384",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6080,
      "text_ar": "فصل: إذا تعدد المجتهدون فللمقلد سؤال من شاء 385",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6081,
      "text_ar": "وقيل: يلزمه سؤال الأفضل 386",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6082,
      "text_ar": "دليل المذهب الأول 386",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6083,
      "text_ar": "دليل المذهب الثاني 387",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6084,
      "text_ar": "أقوال أخرى في المسألة 388",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6085,
      "text_ar": "في ترتيب الأدلة ومعرفة الترجيح.",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6086,
      "text_ar": "على المجتهد -أولا- أن ينظر إلى الإجماع 389",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6087,
      "text_ar": "ثم ينظر في الكتاب والسنة المتواترة 389",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6088,
      "text_ar": "ثم في أخبار الآحاد 390",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6089,
      "text_ar": "ثم في القياس 390",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6090,
      "text_ar": "تعريف التعارض 390",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6091,
      "text_ar": "وجوه الترجيح في الأخبار.",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6092,
      "text_ar": "الأول: يتعلق بالسند -وهو من خمسة وجوه: 391",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6093,
      "text_ar": "أحدها: كثرة الرواة، وهو مذهب الشافعي 391",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6094,
      "text_ar": "قال بعض الحنفية: لا يرجح بكثرة الرواة 391",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6095,
      "text_ar": "الرد على مذهب الحنفية 392",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6096,
      "text_ar": "الثاني: أن يكون أحد الراويين معروفا بزيادة التيقظ وعدم الغلط 393",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6097,
      "text_ar": "الثالث: أن يكون أورع وأتقى من الآخر 393",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6098,
      "text_ar": "الرابع: أن يكون أحدهما صاحب الواقعة 393",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6099,
      "text_ar": "الخامس: أن يكون أحدهما باشر القصة 394",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6100,
      "text_ar": "الوجه الثاني: الترجيح لأمر يعود إلى المتن 394",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6101,
      "text_ar": "وهو من عدة وجوه:",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6102,
      "text_ar": "الأول: أن يشهد القرآن أو السنة أو الإجماع بوجوب العمل على وفق الخبر، أو يعضده قياس أو عمل الخلفاء أو قول صحابي 394",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6103,
      "text_ar": "الثاني: أن يختلف في رفع أحد الخبرين ويتفق على رفع الآخر 395",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6104,
      "text_ar": "الثالث: أن يكون راوي أحدهما نقل عنه خلافه 395",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6105,
      "text_ar": "الرابع: أن يكون أحدهما مرسلا والآخر متصلا 395",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6106,
      "text_ar": "الترجيح لأمر خارج وصوره 396",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6107,
      "text_ar": "في ترجيح المعاني.",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6108,
      "text_ar": "ترجح العلة بما يرجح به الخبر 397",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6109,
      "text_ar": "ترجح العلة الموافقة لدليل آخر 397",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6110,
      "text_ar": "خلاف العلماء في الترجيح بين العلة الحاظرة والمبيحة 397",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6111,
      "text_ar": "خلاف العلماء في الترجيح بين العلة الحكمية والحسية 398",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6112,
      "text_ar": "الخلاف في الترجيح بين العلة التي أوصافها أقل والتي أوصافها أكثر 399",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6113,
      "text_ar": "ترجح العلة المنتزعة من الأصول على المنتزعة من أصل واحد 399",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6114,
      "text_ar": "ترجح العلة المطردة المنعكسة على ما لا ينعكس 399",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6115,
      "text_ar": "ترجح العلة المتعدية على العلة القاصرة 399",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6116,
      "text_ar": "ترجح ما كانت علته وصفا على ما كانت علته اسما 400",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6117,
      "text_ar": "ترجح ما كانت علته إثباتا على التعليل بالنفي 400",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6118,
      "text_ar": "ترجح العلة المردودة إلى أصل قاس الشارع عليه 400",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6119,
      "text_ar": "ترجح كل علة قوي أصلها 401",
      "text_en": "",
      "reference": "...."
    },
    {
      "id": 6120,
      "text_ar": "أولا: فهرس الآيات القرآنية.",
      "text_en": "",
      "reference": "الفهارس العامة:"
    }
  ]
}