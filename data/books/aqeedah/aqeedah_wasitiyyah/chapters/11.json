{
  "book_id": "aqeedah_wasitiyyah",
  "chapter_id": 11,
  "title_ar": "293-",
  "title_en": "",
  "entries": [
    {
      "id": 510,
      "text_ar": "فيؤثرون: كلام الله على غيره من كلام أصناف الناس.",
      "text_en": "",
      "reference": "294-"
    },
    {
      "id": 511,
      "text_ar": "ويقدمون: هدي محمد صلى الله عليه وسلم على هدي كل أحد.",
      "text_en": "",
      "reference": "295-"
    },
    {
      "id": 512,
      "text_ar": "وبهذا سموا: «أهل الكتاب والسنة» .",
      "text_en": "",
      "reference": "295-"
    },
    {
      "id": 513,
      "text_ar": "وسموا «أهل الجماعة» ؛ لأن الجماعة هي الاجتماع. وضدها الفرقة، وإن كان لفظ «الجماعة» قد صار اسما لنفس القوم المجتمعين.",
      "text_en": "",
      "reference": "296-"
    },
    {
      "id": 514,
      "text_ar": "والإجماع: هو الأصل الثالث؛ الذي يعتمد عليه في العلم والدين.",
      "text_en": "",
      "reference": "297-"
    },
    {
      "id": 515,
      "text_ar": "وهم يزنون بهذه الأصول الثلاثة جميع ما عليه الناس من أقوال وأعمال باطنة أو ظاهرة، مما له تعلق بالدين.",
      "text_en": "",
      "reference": "298-"
    },
    {
      "id": 516,
      "text_ar": "والإجماع الذي ينضبط: هو ما كان عليه «السلف الصالح» ؛ إذ بعدهم كثر الاختلاف، وانتشرت الأمة.",
      "text_en": "",
      "reference": "299-"
    },
    {
      "id": 517,
      "text_ar": "* * * *",
      "text_en": "",
      "reference": "299-"
    },
    {
      "id": 518,
      "text_ar": "من خصال أهل السنة الحميدة]",
      "text_en": "",
      "reference": "[الفصل الثاني:"
    },
    {
      "id": 519,
      "text_ar": "• ثم هم مع هذه الأصول:",
      "text_en": "",
      "reference": "فصل في بيان مكملات العقيدة من مكارم الأخلاق ومحاسن الأعمال التي يتحلى بها أهل السنة والجماعة"
    },
    {
      "id": 520,
      "text_ar": "يأمرون: بالمعروف، وينهون عن المنكر، على ما توجبه الشريعة.",
      "text_en": "",
      "reference": "300-"
    },
    {
      "id": 521,
      "text_ar": "ويرون إقامة: الحج، والجهاد، والجمع، والأعياد؛ مع الأمراء؛ أبرارا كانوا، أو فجارا.",
      "text_en": "",
      "reference": "301-"
    },
    {
      "id": 522,
      "text_ar": "ويحافظون على: الجماعات.",
      "text_en": "",
      "reference": "302-"
    },
    {
      "id": 523,
      "text_ar": "ويدينون: بالنصيحة للأمة.",
      "text_en": "",
      "reference": "303-"
    },
    {
      "id": 524,
      "text_ar": "ويعتقدون:",
      "text_en": "",
      "reference": "304-"
    },
    {
      "id": 525,
      "text_ar": "- معنى قوله صلى الله عليه وسلم: «المؤمن للمؤمن كالبنيان، يشد بعضه بعضا» وشبك بين أصابعه صلى الله عليه وسلم.",
      "text_en": "",
      "reference": "304-"
    },
    {
      "id": 526,
      "text_ar": "- وقوله صلى الله عليه وسلم: «مثل المؤمنين في توادهم وتراحمهم وتعاطفهم؛ كمثل الجسد، إذا اشتكى منه عضو؛ تداعى له سائر الجسد بالحمى والسهر» .",
      "text_en": "",
      "reference": "304-"
    },
    {
      "id": 527,
      "text_ar": "ويأمرون:",
      "text_en": "",
      "reference": "305-"
    },
    {
      "id": 528,
      "text_ar": "- بالصبر على البلاء.",
      "text_en": "",
      "reference": "305-"
    },
    {
      "id": 529,
      "text_ar": "- والشكر عند الرخاء.",
      "text_en": "",
      "reference": "305-"
    },
    {
      "id": 530,
      "text_ar": "- والرضا بمر القضاء.",
      "text_en": "",
      "reference": "305-"
    },
    {
      "id": 531,
      "text_ar": "ويدعون إلى:",
      "text_en": "",
      "reference": "306-"
    },
    {
      "id": 532,
      "text_ar": "- مكارم الأخلاق.",
      "text_en": "",
      "reference": "306-"
    },
    {
      "id": 533,
      "text_ar": "- ومحاسن الأعمال.",
      "text_en": "",
      "reference": "306-"
    },
    {
      "id": 534,
      "text_ar": "ويعتقدون: معنى قول النبي صلى الله عليه وسلم: «أكمل المؤمنين إيمانا أحسنهم خلقا» .",
      "text_en": "",
      "reference": "307-"
    },
    {
      "id": 535,
      "text_ar": "ويندبون إلى:",
      "text_en": "",
      "reference": "308-"
    },
    {
      "id": 536,
      "text_ar": "- أن تصل من قطعك.",
      "text_en": "",
      "reference": "308-"
    },
    {
      "id": 537,
      "text_ar": "- وتعطي من حرمك.",
      "text_en": "",
      "reference": "308-"
    },
    {
      "id": 538,
      "text_ar": "- وتعفو عمن ظلمك.",
      "text_en": "",
      "reference": "308-"
    },
    {
      "id": 539,
      "text_ar": "ويأمرون:",
      "text_en": "",
      "reference": "309-"
    },
    {
      "id": 540,
      "text_ar": "- ببر الوالدين.",
      "text_en": "",
      "reference": "309-"
    },
    {
      "id": 541,
      "text_ar": "- وصلة الأرحام.",
      "text_en": "",
      "reference": "309-"
    },
    {
      "id": 542,
      "text_ar": "- وحسن الجوار.",
      "text_en": "",
      "reference": "309-"
    },
    {
      "id": 543,
      "text_ar": "- والإحسان إلى: اليتامى، والمساكين، وابن السبيل.",
      "text_en": "",
      "reference": "309-"
    },
    {
      "id": 544,
      "text_ar": "- والرفق بالمملوك.",
      "text_en": "",
      "reference": "309-"
    },
    {
      "id": 545,
      "text_ar": "وينهون عن:",
      "text_en": "",
      "reference": "310-"
    },
    {
      "id": 546,
      "text_ar": "- الفخر، والخيلاء.",
      "text_en": "",
      "reference": "310-"
    },
    {
      "id": 547,
      "text_ar": "- والبغي، والاستطالة على الخلق بحق أو بغير حق.",
      "text_en": "",
      "reference": "310-"
    },
    {
      "id": 548,
      "text_ar": "ويأمرون: بمعالي الأخلاق.",
      "text_en": "",
      "reference": "311-"
    },
    {
      "id": 549,
      "text_ar": "وينهون عن: سفسافها.",
      "text_en": "",
      "reference": "312-"
    },
    {
      "id": 550,
      "text_ar": "وكل ما يقولونه أو يفعلونه من هذا أو غيره؛ فإنما هم فيه متبعون للكتاب والسنة.",
      "text_en": "",
      "reference": "313-"
    },
    {
      "id": 551,
      "text_ar": "وطريقتهم: هي دين الإسلام؛ الذي بعث الله به محمدا صلى الله عليه وسلم.",
      "text_en": "",
      "reference": "314-"
    },
    {
      "id": 552,
      "text_ar": "لكن لما أخبر صلى الله عليه وسلم: «أن أمته ستفترق على ثلاث وسبعين فرقة؛ كلها في النار إلا واحدة؛ وهي الجماعة» .",
      "text_en": "",
      "reference": "315-"
    },
    {
      "id": 553,
      "text_ar": "وفي حديث عنه أنه قال: «هم من كان على مثل ما أنا عليه وأصحابي» ؛ صار المتمسكون بالإسلام المحض الخالص عن الشوب هم «أهل السنة والجماعة» .",
      "text_en": "",
      "reference": "316-"
    },
    {
      "id": 554,
      "text_ar": "وفيهم: الصديقون، والشهداء، والصالحون.",
      "text_en": "",
      "reference": "317-"
    },
    {
      "id": 555,
      "text_ar": "ومنهم: أعلام الهدى، ومصابيح الدجى.",
      "text_en": "",
      "reference": "318-"
    },
    {
      "id": 556,
      "text_ar": "أولوا المناقب المأثورة، والفضائل المذكورة.",
      "text_en": "",
      "reference": "318-"
    },
    {
      "id": 557,
      "text_ar": "وفيهم: الأبدال.",
      "text_en": "",
      "reference": "319-"
    },
    {
      "id": 558,
      "text_ar": "ومنهم: الأئمة؛ الذين أجمع المسلمون على",
      "text_en": "",
      "reference": "320-"
    },
    {
      "id": 559,
      "text_ar": "هدايتهم ودرايتهم.",
      "text_en": "",
      "reference": "320-"
    }
  ]
}