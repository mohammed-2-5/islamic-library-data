{
  "book_id": "aqeedah_wasitiyyah",
  "chapter_id": 7,
  "title_ar": "179-",
  "title_en": "",
  "entries": [
    {
      "id": 310,
      "text_ar": "القيامة الكبرى وأهوالها]",
      "text_en": "",
      "reference": "[الفصل الثاني:"
    },
    {
      "id": 311,
      "text_ar": "ثم بعد هذه الفتنة: إما نعيم، وإما عذاب، إلى يوم القيامة الكبرى.",
      "text_en": "",
      "reference": "180-"
    },
    {
      "id": 312,
      "text_ar": "فتعاد «الأرواح إلى الأجساد» .",
      "text_en": "",
      "reference": "181-"
    },
    {
      "id": 313,
      "text_ar": "فتقوم القيامة التي أخبر الله تعالى بها في كتابه، على لسان رسوله صلى الله عليه وسلم، وأجمع عليها المسلمون.",
      "text_en": "",
      "reference": "182-"
    },
    {
      "id": 314,
      "text_ar": "«فيقوم الناس من قبورهم» لرب العالمين، حفاة عراة غرلا.",
      "text_en": "",
      "reference": "183-"
    },
    {
      "id": 315,
      "text_ar": "* * * *",
      "text_en": "",
      "reference": "183-"
    },
    {
      "id": 316,
      "text_ar": "وتدنو منهم الشمس.",
      "text_en": "",
      "reference": "184-"
    },
    {
      "id": 317,
      "text_ar": "* * * *",
      "text_en": "",
      "reference": "184-"
    },
    {
      "id": 318,
      "text_ar": "ويلجمهم العرق.",
      "text_en": "",
      "reference": "185-"
    },
    {
      "id": 319,
      "text_ar": "* * * *",
      "text_en": "",
      "reference": "185-"
    },
    {
      "id": 320,
      "text_ar": "وتنصب الموازين، فيوزن فيها أعمال العباد.",
      "text_en": "",
      "reference": "186-"
    },
    {
      "id": 321,
      "text_ar": "{فمن ثقلت موازينه فأولئك هم المفلحون • ومن خفت موازينه فأولئك الذين خسروا أنفسهم في جهنم خالدون} [المؤمنون: 102 - 103] .",
      "text_en": "",
      "reference": "186-"
    },
    {
      "id": 322,
      "text_ar": "وتنشر الدواوين، وهي صحائف الأعمال.",
      "text_en": "",
      "reference": "187-"
    },
    {
      "id": 323,
      "text_ar": "- فآخذ كتابه بيمينه.",
      "text_en": "",
      "reference": "187-"
    },
    {
      "id": 324,
      "text_ar": "- وآخذ كتابه بشماله.",
      "text_en": "",
      "reference": "187-"
    },
    {
      "id": 325,
      "text_ar": "- أو من وراء ظهره.",
      "text_en": "",
      "reference": "187-"
    },
    {
      "id": 326,
      "text_ar": "كما قال سبحانه وتعالى: {وكل إنسان ألزمناه طائره في عنقه ونخرج له يوم القيامة كتابا يلقاه منشورا • اقرأ كتابك كفى بنفسك اليوم عليك حسيبا} [الإسراء: 13 - 14] .",
      "text_en": "",
      "reference": "188-"
    },
    {
      "id": 327,
      "text_ar": "* * * *",
      "text_en": "",
      "reference": "188-"
    },
    {
      "id": 328,
      "text_ar": "ويحاسب الله الخلق.",
      "text_en": "",
      "reference": "189-"
    },
    {
      "id": 329,
      "text_ar": "ويخلو بعبده المؤمن، فيقرره بذنوبه كما وصف ذلك في الكتاب والسنة.",
      "text_en": "",
      "reference": "190-"
    },
    {
      "id": 330,
      "text_ar": "وأما الكفار؛ فلا يحاسبون محاسبة من توزن حسناته",
      "text_en": "",
      "reference": "191-"
    },
    {
      "id": 331,
      "text_ar": "وسيئاته فإنهم لا حسنات لهم، ولكن تعد أعمالهم، وتحصى فيوقفون عليها، ويقررون بها، ويجزون بها.",
      "text_en": "",
      "reference": "191-"
    },
    {
      "id": 332,
      "text_ar": "* * * *",
      "text_en": "",
      "reference": "191-"
    },
    {
      "id": 333,
      "text_ar": "وفي عرصة القيامة: «الحوض المورود لمحمد صلى الله عليه وسلم» .",
      "text_en": "",
      "reference": "192-"
    },
    {
      "id": 334,
      "text_ar": "ماؤه: أشد بياضا من اللبن وأحلى من العسل.",
      "text_en": "",
      "reference": "193-"
    },
    {
      "id": 335,
      "text_ar": "آنيته: عدد نجوم السماء.",
      "text_en": "",
      "reference": "194-"
    },
    {
      "id": 336,
      "text_ar": "طوله: شهر، وعرضه: شهر.",
      "text_en": "",
      "reference": "195-"
    },
    {
      "id": 337,
      "text_ar": "من شرب منه شربة؛ لم يظمأ بعدها أبدا.",
      "text_en": "",
      "reference": "196-"
    },
    {
      "id": 338,
      "text_ar": "* * * *",
      "text_en": "",
      "reference": "196-"
    },
    {
      "id": 339,
      "text_ar": "«والصراط» منصوب على متن جهنم.",
      "text_en": "",
      "reference": "197-"
    },
    {
      "id": 340,
      "text_ar": "وهو الجسر الذي بين الجنة والنار.",
      "text_en": "",
      "reference": "198-"
    },
    {
      "id": 341,
      "text_ar": "يمر الناس عليه على قدر أعمالهم:",
      "text_en": "",
      "reference": "199-"
    },
    {
      "id": 342,
      "text_ar": "- فمنهم من يمر كلمح البصر.",
      "text_en": "",
      "reference": "199-"
    },
    {
      "id": 343,
      "text_ar": "- ومنهم من يمر كالبرق.",
      "text_en": "",
      "reference": "199-"
    },
    {
      "id": 344,
      "text_ar": "- ومنهم من يمر كالريح.",
      "text_en": "",
      "reference": "199-"
    },
    {
      "id": 345,
      "text_ar": "- ومنهم من يمر كالفرس الجواد.",
      "text_en": "",
      "reference": "199-"
    },
    {
      "id": 346,
      "text_ar": "- ومنهم من يمر كركاب الإبل.",
      "text_en": "",
      "reference": "199-"
    },
    {
      "id": 347,
      "text_ar": "- ومنهم من يعدو عدوا.",
      "text_en": "",
      "reference": "199-"
    },
    {
      "id": 348,
      "text_ar": "- ومنهم من يمشي مشيا.",
      "text_en": "",
      "reference": "199-"
    },
    {
      "id": 349,
      "text_ar": "- ومنهم من يزحف زحفا.",
      "text_en": "",
      "reference": "199-"
    },
    {
      "id": 350,
      "text_ar": "- ومنهم من يخطف فيلقى في جهنم؛ فإن الجسر عليه كلاليب تخطف الناس بأعمالهم.",
      "text_en": "",
      "reference": "199-"
    },
    {
      "id": 351,
      "text_ar": "فمن مر على الصراط؛ دخل الجنة.",
      "text_en": "",
      "reference": "200-"
    },
    {
      "id": 352,
      "text_ar": "فإذا عبروا عليه؛ وقفوا على قنطرة بين الجنة والنار؛ فيقتص لبعضهم من بعض، فإذا هذبوا ونقوا؛ أذن لهم في دخول الجنة.",
      "text_en": "",
      "reference": "201-"
    },
    {
      "id": 353,
      "text_ar": "* * * *",
      "text_en": "",
      "reference": "201-"
    },
    {
      "id": 354,
      "text_ar": "وأول من يستفتح باب الجنة: محمد صلى الله عليه وسلم.",
      "text_en": "",
      "reference": "202-"
    },
    {
      "id": 355,
      "text_ar": "وأول من يدخل الجنة من الأمم: أمته صلى الله عليه وسلم.",
      "text_en": "",
      "reference": "203-"
    },
    {
      "id": 356,
      "text_ar": "* * * *",
      "text_en": "",
      "reference": "203-"
    },
    {
      "id": 357,
      "text_ar": "وله صلى الله عليه وسلم في القيامة ثلاث شفاعات:",
      "text_en": "",
      "reference": "204-"
    },
    {
      "id": 358,
      "text_ar": "أما الشفاعة الأولى: فيشفع في أهل الموقف، حتى يقضى",
      "text_en": "",
      "reference": "205-"
    },
    {
      "id": 359,
      "text_ar": "بينهم بعد أن يتراجع الأنبياء - آدم ونوح وإبراهيم وموسى وعيسى ابن مريم - الشفاعة حتى تنتهي إليه.",
      "text_en": "",
      "reference": "205-"
    }
  ]
}