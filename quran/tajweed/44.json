{"surah": 44, "verses": [{"id": 1, "text": "ح<tajweed class=madda_necessary>مٓ</tajweed> <span class=end>١</span>"}, {"id": 2, "text": "وَ<tajweed class=ham_wasl>ٱ</tajweed>لْكِتَ<tajweed class=madda_normal>ـٰ</tajweed>بِ <tajweed class=ham_wasl>ٱ</tajweed>لْمُب<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٢</span>"}, {"id": 3, "text": "إِ<tajweed class=ghunnah>نّ</tajweed><tajweed class=madda_obligatory>َآ</tajweed> أَ<tajweed class=ikhafa>نز</tajweed>َلْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ فِى لَيْلَ<tajweed class=idgham_ghunnah>ةٍ م</tajweed>ُّبَ<tajweed class=madda_normal>ـٰ</tajweed>رَكَةٍ‌ۚ إِ<tajweed class=ghunnah>نّ</tajweed>َا كُ<tajweed class=ghunnah>نّ</tajweed>َا مُ<tajweed class=ikhafa>نذ</tajweed>ِر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣</span>"}, {"id": 4, "text": "فِيهَا يُفْرَقُ كُلُّ أَمْرٍ حَك<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>٤</span>"}, {"id": 5, "text": "أَمْ<tajweed class=idgham_ghunnah>رًا م</tajweed>ِّنْ عِ<tajweed class=ikhafa>ند</tajweed>ِن<tajweed class=madda_obligatory>َآ‌ۚ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َا كُ<tajweed class=ghunnah>نّ</tajweed>َا مُرْسِل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٥</span>"}, {"id": 6, "text": "رَحْمَ<tajweed class=idgham_ghunnah>ةً م</tajweed>ّ<tajweed class=idgham_wo_ghunnah>ِن ر</tajweed>َّبِّكَ‌ۚ إِ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=madda_normal>ۥ</tajweed> هُوَ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>سَّمِيعُ <tajweed class=ham_wasl>ٱ</tajweed>لْعَل<tajweed class=madda_permissible>ِي</tajweed>مُ <span class=end>٦</span>"}, {"id": 7, "text": "رَبِّ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>سَّمَ<tajweed class=madda_normal>ـٰ</tajweed>و<tajweed class=madda_normal>َٲ</tajweed>تِ وَ<tajweed class=ham_wasl>ٱ</tajweed>لْأَرْضِ وَمَا بَيْنَهُم<tajweed class=madda_obligatory>َآ‌ۖ</tajweed> إِ<tajweed class=ikhafa>ن ك</tajweed>ُ<tajweed class=ikhafa>نت</tajweed><tajweed class=idgham_shafawi>ُم م</tajweed>ُّوقِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٧</span>"}, {"id": 8, "text": "ل<tajweed class=madda_obligatory>َآ</tajweed> إِلَ<tajweed class=madda_normal>ـٰ</tajweed>هَ إِلَّا هُوَ يُحْى<tajweed class=madda_normal>ِۦ</tajweed> وَيُمِيتُ‌ۖ رَبُّكُمْ وَرَبُّ ءَاب<tajweed class=madda_obligatory>َا</tajweed>ٓئِكُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْأَوَّل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٨</span>"}, {"id": 9, "text": "بَلْ هُمْ فِى شَ<tajweed class=idgham_ghunnah>كٍّ ي</tajweed>َلْعَب<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٩</span>"}, {"id": 10, "text": "فَ<tajweed class=ham_wasl>ٱ</tajweed>رْتَقِ<tajweed class=qalaqah>بْ</tajweed> يَوْمَ تَأْتِى <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>سَّم<tajweed class=madda_obligatory>َا</tajweed>ٓءُ بِدُخَا<tajweed class=idgham_ghunnah>نٍ م</tajweed>ُّب<tajweed class=madda_permissible>ِي</tajweed>نٍ <span class=end>١٠</span>"}, {"id": 11, "text": "يَغْشَى <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed><tajweed class=ghunnah>نّ</tajweed>َاسَ‌ۖ هَ<tajweed class=madda_normal>ـٰ</tajweed>ذَا عَذَابٌ أَل<tajweed class=madda_permissible>ِي</tajweed>مٌ <span class=end>١١</span>"}, {"id": 12, "text": "رَّبَّنَا <tajweed class=ham_wasl>ٱ</tajweed>كْشِفْ عَ<tajweed class=ghunnah>نّ</tajweed>َا <tajweed class=ham_wasl>ٱ</tajweed>لْعَذَابَ إِ<tajweed class=ghunnah>نّ</tajweed>َا مُؤْمِن<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٢</span>"}, {"id": 13, "text": "أَ<tajweed class=ghunnah>نّ</tajweed>َىٰ لَهُمُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>ذِّكْرَىٰ وَقَ<tajweed class=qalaqah>دْ</tajweed> ج<tajweed class=madda_obligatory>َا</tajweed>ٓءَهُمْ رَسُو<tajweed class=idgham_ghunnah>لٌ م</tajweed>ُّب<tajweed class=madda_permissible>ِي</tajweed>نٌ <span class=end>١٣</span>"}, {"id": 14, "text": "ثُ<tajweed class=ghunnah>مّ</tajweed>َ تَوَلَّوْ<tajweed class=slnt>اْ</tajweed> عَنْهُ وَقَالُو<tajweed class=slnt>اْ</tajweed> مُعَلَّ<tajweed class=idgham_ghunnah>مٌ م</tajweed>َّ<tajweed class=qalaqah>جْ</tajweed>ن<tajweed class=madda_permissible>ُو</tajweed>نٌ <span class=end>١٤</span>"}, {"id": 15, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َا كَاشِفُو<tajweed class=slnt>اْ</tajweed> <tajweed class=ham_wasl>ٱ</tajweed>لْعَذَابِ قَلِيلاً‌ۚ إِ<tajweed class=ghunnah>نّ</tajweed>َكُمْ ع<tajweed class=madda_obligatory>َا</tajweed>ٓئِد<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٥</span>"}, {"id": 16, "text": "يَوْمَ نَ<tajweed class=qalaqah>بْ</tajweed>طِشُ <tajweed class=ham_wasl>ٱ</tajweed>لْبَ<tajweed class=qalaqah>طْ</tajweed>شَةَ <tajweed class=ham_wasl>ٱ</tajweed>لْكُ<tajweed class=qalaqah>بْ</tajweed>رَ<tajweed class=madda_obligatory>ىٰٓ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َا مُ<tajweed class=ikhafa>نت</tajweed>َقِم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٦</span>"}, {"id": 17, "text": "۞ وَلَقَ<tajweed class=qalaqah>دْ</tajweed> فَتَ<tajweed class=ghunnah>نّ</tajweed>َا قَ<tajweed class=qalaqah>بْ</tajweed>لَهُمْ قَوْمَ فِرْعَوْنَ وَج<tajweed class=madda_obligatory>َا</tajweed>ٓءَهُمْ رَسُو<tajweed class=ikhafa>لٌ ك</tajweed>َر<tajweed class=madda_permissible>ِي</tajweed>مٌ <span class=end>١٧</span>"}, {"id": 18, "text": "أَنْ أَدّ<tajweed class=madda_obligatory>ُوٓ</tajweed><tajweed class=slnt>اْ</tajweed> إِلَىَّ عِبَادَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهِ‌ۖ إِ<tajweed class=ghunnah>نّ</tajweed>ِى لَكُمْ رَسُولٌ أَم<tajweed class=madda_permissible>ِي</tajweed>نٌ <span class=end>١٨</span>"}, {"id": 19, "text": "وَأ<tajweed class=idgham_wo_ghunnah>َن ل</tajweed>َّا تَعْلُو<tajweed class=slnt>اْ</tajweed> عَلَى <tajweed class=ham_wasl>ٱ</tajweed>للَّهِ‌ۖ إِ<tajweed class=ghunnah>نّ</tajweed><tajweed class=madda_obligatory>ِىٓ</tajweed> ءَاتِيك<tajweed class=ikhafa_shafawi>ُم ب</tajweed>ِسُلْطَ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=idgham_ghunnah>نٍ م</tajweed>ُّب<tajweed class=madda_permissible>ِي</tajweed>نٍ <span class=end>١٩</span>"}, {"id": 20, "text": "وَإِ<tajweed class=ghunnah>نّ</tajweed>ِى عُذْتُ بِرَبِّى وَرَبِّكُمْ أَ<tajweed class=ikhafa>ن ت</tajweed>َرْجُم<tajweed class=madda_permissible>ُو</tajweed>نِ <span class=end>٢٠</span>"}, {"id": 21, "text": "وَإ<tajweed class=idgham_wo_ghunnah>ِن ل</tajweed>َّمْ تُؤْمِنُو<tajweed class=slnt>اْ</tajweed> لِى فَ<tajweed class=ham_wasl>ٱ</tajweed>عْتَزِل<tajweed class=madda_permissible>ُو</tajweed>نِ <span class=end>٢١</span>"}, {"id": 22, "text": "فَدَعَا رَبَّهُ<tajweed class=madda_obligatory>ۥٓ</tajweed> أَ<tajweed class=ghunnah>نّ</tajweed>َ هَ<tajweed class=madda_obligatory>ـٰٓ</tajweed>ؤُل<tajweed class=madda_obligatory>َا</tajweed>ٓءِ قَوْ<tajweed class=idgham_ghunnah>مٌ م</tajweed>ُّ<tajweed class=qalaqah>جْ</tajweed>رِم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٢</span>"}, {"id": 23, "text": "فَأَسْرِ بِعِبَادِى لَيْلاً إِ<tajweed class=ghunnah>نّ</tajweed>َك<tajweed class=idgham_shafawi>ُم م</tajweed>ُّتَّبَع<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٣</span>"}, {"id": 24, "text": "وَ<tajweed class=ham_wasl>ٱ</tajweed>تْرُكِ <tajweed class=ham_wasl>ٱ</tajweed>لْبَحْرَ رَهْوًا‌ۖ إِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ جُن<tajweed class=idgham_ghunnah>دٌ م</tajweed>ُّغْرَق<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٤</span>"}, {"id": 25, "text": "كَمْ تَرَكُو<tajweed class=slnt>اْ</tajweed> مِ<tajweed class=ikhafa>ن ج</tajweed>َ<tajweed class=ghunnah>نّ</tajweed>َ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=idgham_ghunnah>تٍ و</tajweed>َعُي<tajweed class=madda_permissible>ُو</tajweed>نٍ <span class=end>٢٥</span>"}, {"id": 26, "text": "وَزُرُو<tajweed class=idgham_ghunnah>عٍ و</tajweed>َمَقَا<tajweed class=ikhafa>مٍ ك</tajweed>َر<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>٢٦</span>"}, {"id": 27, "text": "وَنَعْمَ<tajweed class=ikhafa>ةٍ ك</tajweed>َانُو<tajweed class=slnt>اْ</tajweed> فِيهَا فَ<tajweed class=madda_normal>ـٰ</tajweed>كِه<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٢٧</span>"}, {"id": 28, "text": "كَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ‌ۖ وَأَوْرَثْنَ<tajweed class=madda_normal>ـٰ</tajweed>هَا قَوْمًا ءَاخَر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٢٨</span>"}, {"id": 29, "text": "فَمَا بَكَتْ عَلَيْهِمُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>سَّم<tajweed class=madda_obligatory>َا</tajweed>ٓءُ وَ<tajweed class=ham_wasl>ٱ</tajweed>لْأَرْضُ وَمَا كَانُو<tajweed class=slnt>اْ</tajweed> مُ<tajweed class=ikhafa>نظ</tajweed>َر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٢٩</span>"}, {"id": 30, "text": "وَلَقَ<tajweed class=qalaqah>دْ</tajweed> نَجَّيْنَا بَن<tajweed class=madda_obligatory>ِىٓ</tajweed> إِسْر<tajweed class=madda_obligatory>َٲ</tajweed>ٓءِيلَ مِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْعَذَابِ <tajweed class=ham_wasl>ٱ</tajweed>لْمُه<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٣٠</span>"}, {"id": 31, "text": "مِ<tajweed class=ikhafa>ن ف</tajweed>ِرْعَوْنَ‌ۚ إِ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=madda_normal>ۥ</tajweed> كَانَ عَالِ<tajweed class=idgham_ghunnah>يًا م</tajweed>ِّنَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُسْرِف<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣١</span>"}, {"id": 32, "text": "وَلَقَدِ <tajweed class=ham_wasl>ٱ</tajweed>خْتَرْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُمْ عَلَىٰ عِلْمٍ عَلَى <tajweed class=ham_wasl>ٱ</tajweed>لْعَ<tajweed class=madda_normal>ـٰ</tajweed>لَم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٢</span>"}, {"id": 33, "text": "وَءَاتَيْنَ<tajweed class=madda_normal>ـٰ</tajweed>ه<tajweed class=idgham_shafawi>ُم م</tajweed>ِّنَ <tajweed class=ham_wasl>ٱ</tajweed>لْأَيَ<tajweed class=madda_normal>ـٰ</tajweed>تِ مَا فِيهِ بَلَ<tajweed class=madda_obligatory>ـٰٓ</tajweed><tajweed class=idgham_ghunnah>ؤٌاْ م</tajweed>ُّب<tajweed class=madda_permissible>ِي</tajweed>نٌ <span class=end>٣٣</span>"}, {"id": 34, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َ هَ<tajweed class=madda_obligatory>ـٰٓ</tajweed>ؤُل<tajweed class=madda_obligatory>َا</tajweed>ٓءِ لَيَقُول<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٤</span>"}, {"id": 35, "text": "إِنْ هِىَ إِلَّا مَوْتَتُنَا <tajweed class=ham_wasl>ٱ</tajweed>لْأُولَىٰ وَمَا نَحْنُ بِمُ<tajweed class=ikhafa>نش</tajweed>َر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٥</span>"}, {"id": 36, "text": "فَأْتُو<tajweed class=slnt>اْ</tajweed> بِـَٔـاب<tajweed class=madda_obligatory>َا</tajweed>ٓئِن<tajweed class=madda_obligatory>َآ</tajweed> إِ<tajweed class=ikhafa>ن ك</tajweed>ُ<tajweed class=ikhafa>نت</tajweed>ُمْ صَ<tajweed class=madda_normal>ـٰ</tajweed>دِق<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٦</span>"}, {"id": 37, "text": "أَهُمْ خَيْرٌ أَمْ قَوْمُ تُبَّ<tajweed class=idgham_ghunnah>عٍ و</tajweed>َ<tajweed class=ham_wasl>ٱ</tajweed>لَّذِينَ مِ<tajweed class=ikhafa>ن ق</tajweed>َ<tajweed class=qalaqah>بْ</tajweed>لِهِمْ‌ۚ أَهْلَكْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُمْ‌ۖ إِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ كَانُو<tajweed class=slnt>اْ</tajweed> مُ<tajweed class=qalaqah>جْ</tajweed>رِم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٧</span>"}, {"id": 38, "text": "وَمَا خَلَ<tajweed class=qalaqah>قْ</tajweed>نَا <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>سَّمَ<tajweed class=madda_normal>ـٰ</tajweed>و<tajweed class=madda_normal>َٲ</tajweed>تِ وَ<tajweed class=ham_wasl>ٱ</tajweed>لْأَرْضَ وَمَا بَيْنَهُمَا لَ<tajweed class=madda_normal>ـٰ</tajweed>عِب<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٨</span>"}, {"id": 39, "text": "مَا خَلَ<tajweed class=qalaqah>قْ</tajweed>نَ<tajweed class=madda_normal>ـٰ</tajweed>هُم<tajweed class=madda_obligatory>َآ</tajweed> إِلَّا بِ<tajweed class=ham_wasl>ٱ</tajweed>لْحَقِّ وَلَ<tajweed class=madda_normal>ـٰ</tajweed>كِ<tajweed class=ghunnah>نّ</tajweed>َ أَكْثَرَهُمْ لَا يَعْلَم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٩</span>"}, {"id": 40, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َ يَوْمَ <tajweed class=ham_wasl>ٱ</tajweed>لْفَصْلِ مِيقَ<tajweed class=madda_normal>ـٰ</tajweed>تُهُمْ أَ<tajweed class=qalaqah>جْ</tajweed>مَع<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٤٠</span>"}, {"id": 41, "text": "يَوْمَ لَا يُغْنِى مَوْلًى ع<tajweed class=idgham_ghunnah>َن م</tajweed>َّوْ<tajweed class=ikhafa>لًى ش</tajweed>َيْـ<tajweed class=idgham_ghunnah>ـًٔا و</tajweed>َلَا هُمْ يُ<tajweed class=ikhafa>نص</tajweed>َر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٤١</span>"}, {"id": 42, "text": "إِلَّا م<tajweed class=idgham_wo_ghunnah>َن ر</tajweed>َّحِمَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهُ‌ۚ إِ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=madda_normal>ۥ</tajweed> هُوَ <tajweed class=ham_wasl>ٱ</tajweed>لْعَزِيزُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>رَّح<tajweed class=madda_permissible>ِي</tajweed>مُ <span class=end>٤٢</span>"}, {"id": 43, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َ شَجَرَتَ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>زَّقّ<tajweed class=madda_permissible>ُو</tajweed>مِ <span class=end>٤٣</span>"}, {"id": 44, "text": "طَعَامُ <tajweed class=ham_wasl>ٱ</tajweed>لْأَث<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٤٤</span>"}, {"id": 45, "text": "كَ<tajweed class=ham_wasl>ٱ</tajweed>لْمُهْلِ يَغْلِى فِى <tajweed class=ham_wasl>ٱ</tajweed>لْبُط<tajweed class=madda_permissible>ُو</tajweed>نِ <span class=end>٤٥</span>"}, {"id": 46, "text": "كَغَلْىِ <tajweed class=ham_wasl>ٱ</tajweed>لْحَم<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٤٦</span>"}, {"id": 47, "text": "خُذُوهُ فَ<tajweed class=ham_wasl>ٱ</tajweed>عْتِلُوهُ إِلَىٰ سَو<tajweed class=madda_obligatory>َا</tajweed>ٓءِ <tajweed class=ham_wasl>ٱ</tajweed>لْجَح<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٤٧</span>"}, {"id": 48, "text": "ثُ<tajweed class=ghunnah>مّ</tajweed>َ صُبُّو<tajweed class=slnt>اْ</tajweed> فَوْقَ رَأْسِه<tajweed class=madda_normal>ِۦ</tajweed> مِنْ عَذَابِ <tajweed class=ham_wasl>ٱ</tajweed>لْحَم<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٤٨</span>"}, {"id": 49, "text": "ذُ<tajweed class=qalaqah>قْ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َكَ أَ<tajweed class=ikhafa>نت</tajweed>َ <tajweed class=ham_wasl>ٱ</tajweed>لْعَزِيزُ <tajweed class=ham_wasl>ٱ</tajweed>لْكَر<tajweed class=madda_permissible>ِي</tajweed>مُ <span class=end>٤٩</span>"}, {"id": 50, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َ هَ<tajweed class=madda_normal>ـٰ</tajweed>ذَا مَا كُ<tajweed class=ikhafa>نت</tajweed><tajweed class=ikhafa_shafawi>ُم ب</tajweed>ِه<tajweed class=madda_normal>ِۦ</tajweed> تَمْتَر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥٠</span>"}, {"id": 51, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َ <tajweed class=ham_wasl>ٱ</tajweed>لْمُتَّقِينَ فِى مَقَامٍ أَم<tajweed class=madda_permissible>ِي</tajweed>نٍ <span class=end>٥١</span>"}, {"id": 52, "text": "فِى جَ<tajweed class=ghunnah>نّ</tajweed>َ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=idgham_ghunnah>تٍ و</tajweed>َعُي<tajweed class=madda_permissible>ُو</tajweed>نٍ <span class=end>٥٢</span>"}, {"id": 53, "text": "يَلْبَسُونَ مِ<tajweed class=ikhafa>ن س</tajweed>ُ<tajweed class=ikhafa>ند</tajweed>ُ<tajweed class=idgham_ghunnah>سٍ و</tajweed>َإِسْتَ<tajweed class=qalaqah>بْ</tajweed>رَ<tajweed class=idgham_ghunnah>قٍ م</tajweed>ُّتَقَ<tajweed class=madda_normal>ـٰ</tajweed>بِل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٥٣</span>"}, {"id": 54, "text": "كَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ وَزَوَّ<tajweed class=qalaqah>جْ</tajweed>نَ<tajweed class=madda_normal>ـٰ</tajweed>ه<tajweed class=ikhafa_shafawi>ُم ب</tajweed>ِحُورٍ ع<tajweed class=madda_permissible>ِي</tajweed>نٍ <span class=end>٥٤</span>"}, {"id": 55, "text": "يَ<tajweed class=qalaqah>دْ</tajweed>عُونَ فِيهَا بِكُلِّ فَ<tajweed class=madda_normal>ـٰ</tajweed>كِهَةٍ ءَامِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٥٥</span>"}, {"id": 56, "text": "لَا يَذُوقُونَ فِيهَا <tajweed class=ham_wasl>ٱ</tajweed>لْمَوْتَ إِلَّا <tajweed class=ham_wasl>ٱ</tajweed>لْمَوْتَةَ <tajweed class=ham_wasl>ٱ</tajweed>لْأُولَىٰ‌ۖ وَوَقَ<tajweed class=madda_normal>ـٰ</tajweed>هُمْ عَذَابَ <tajweed class=ham_wasl>ٱ</tajweed>لْجَح<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٥٦</span>"}, {"id": 57, "text": "فَضْل<tajweed class=idgham_ghunnah>اً م</tajweed>ّ<tajweed class=idgham_wo_ghunnah>ِن ر</tajweed>َّبِّكَ‌ۚ ذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ هُوَ <tajweed class=ham_wasl>ٱ</tajweed>لْفَوْزُ <tajweed class=ham_wasl>ٱ</tajweed>لْعَظ<tajweed class=madda_permissible>ِي</tajweed>مُ <span class=end>٥٧</span>"}, {"id": 58, "text": "فَإِ<tajweed class=ghunnah>نّ</tajweed>َمَا يَسَّرْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ بِلِسَانِكَ لَعَلَّهُمْ يَتَذَكَّر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥٨</span>"}, {"id": 59, "text": "فَ<tajweed class=ham_wasl>ٱ</tajweed>رْتَقِ<tajweed class=qalaqah>بْ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َه<tajweed class=idgham_shafawi>ُم م</tajweed>ُّرْتَقِب<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥٩</span>"}]}