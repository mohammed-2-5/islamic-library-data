{"surah": 37, "verses": [{"id": 1, "text": "وَ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>صَّ<tajweed class=madda_necessary>ـٰٓ</tajweed>فَّ<tajweed class=madda_normal>ـٰ</tajweed>تِ صَفًّا <span class=end>١</span>"}, {"id": 2, "text": "فَ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>زّ<tajweed class=madda_normal>َٲ</tajweed>جِر<tajweed class=madda_normal>َٲ</tajweed>تِ زَ<tajweed class=qalaqah>جْ</tajweed>رًا <span class=end>٢</span>"}, {"id": 3, "text": "فَ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>تَّ<tajweed class=madda_normal>ـٰ</tajweed>لِيَ<tajweed class=madda_normal>ـٰ</tajweed>تِ ذِكْرًا <span class=end>٣</span>"}, {"id": 4, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َ إِلَ<tajweed class=madda_normal>ـٰ</tajweed>هَكُمْ لَو<tajweed class=madda_normal>َٲ</tajweed>حِ<tajweed class=qalaqah>د</tajweed>ٌ <span class=end>٤</span>"}, {"id": 5, "text": "رَّبُّ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>سَّمَ<tajweed class=madda_normal>ـٰ</tajweed>و<tajweed class=madda_normal>َٲ</tajweed>تِ وَ<tajweed class=ham_wasl>ٱ</tajweed>لْأَرْضِ وَمَا بَيْنَهُمَا وَرَبُّ <tajweed class=ham_wasl>ٱ</tajweed>لْمَشَ<tajweed class=madda_normal>ـٰ</tajweed>رِ<tajweed class=qalaqah>ق</tajweed>ِ <span class=end>٥</span>"}, {"id": 6, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َا زَيَّ<tajweed class=ghunnah>نّ</tajweed>َا <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>سَّم<tajweed class=madda_obligatory>َا</tajweed>ٓءَ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>دُّنْيَا بِزِينَةٍ <tajweed class=ham_wasl>ٱ</tajweed>لْكَوَاكِ<tajweed class=qalaqah>ب</tajweed>ِ <span class=end>٦</span>"}, {"id": 7, "text": "وَحِفْ<tajweed class=idgham_ghunnah>ظًا م</tajweed>ِّ<tajweed class=ikhafa>ن ك</tajweed>ُلِّ شَيْطَ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=idgham_ghunnah>نٍ م</tajweed>َّارِ<tajweed class=qalaqah>د</tajweed>ٍ <span class=end>٧</span>"}, {"id": 8, "text": "لَّا يَسَّ<tajweed class=ghunnah>مّ</tajweed>َعُونَ إِلَى <tajweed class=ham_wasl>ٱ</tajweed>لْمَلَإِ <tajweed class=ham_wasl>ٱ</tajweed>لْأَعْلَىٰ وَيُ<tajweed class=qalaqah>قْ</tajweed>ذَفُونَ مِ<tajweed class=ikhafa>ن ك</tajweed>ُلِّ جَانِ<tajweed class=qalaqah>ب</tajweed>ٍ <span class=end>٨</span>"}, {"id": 9, "text": "دُحُو<tajweed class=idgham_ghunnah>رًا‌ۖ و</tajweed>َلَهُمْ عَذَا<tajweed class=idgham_ghunnah>بٌ و</tajweed>َاصِ<tajweed class=qalaqah>ب</tajweed>ٌ <span class=end>٩</span>"}, {"id": 10, "text": "إِلَّا مَنْ خَطِفَ <tajweed class=ham_wasl>ٱ</tajweed>لْخَ<tajweed class=qalaqah>طْ</tajweed>فَةَ فَأَتْبَعَهُ<tajweed class=madda_normal>ۥ</tajweed> شِهَا<tajweed class=ikhafa>بٌ ث</tajweed>َاقِ<tajweed class=qalaqah>ب</tajweed>ٌ <span class=end>١٠</span>"}, {"id": 11, "text": "فَ<tajweed class=ham_wasl>ٱ</tajweed>سْتَفْتِهِمْ أَهُمْ أَشَدُّ خَلْقًا أ<tajweed class=idgham_shafawi>َم م</tajweed>َّنْ خَلَ<tajweed class=qalaqah>قْ</tajweed>ن<tajweed class=madda_obligatory>َآ‌ۚ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َا خَلَ<tajweed class=qalaqah>قْ</tajweed>نَ<tajweed class=madda_normal>ـٰ</tajweed>ه<tajweed class=idgham_shafawi>ُم م</tajweed>ِّ<tajweed class=ikhafa>ن ط</tajweed>ِي<tajweed class=idgham_wo_ghunnah>نٍ ل</tajweed>َّازِ<tajweed class=qalaqah>ب</tajweed>ِۭ <span class=end>١١</span>"}, {"id": 12, "text": "بَلْ عَجِ<tajweed class=qalaqah>بْ</tajweed>تَ وَيَسْخَر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٢</span>"}, {"id": 13, "text": "وَإِذَا ذُكِّرُو<tajweed class=slnt>اْ</tajweed> لَا يَذْكُر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٣</span>"}, {"id": 14, "text": "وَإِذَا رَأَوْ<tajweed class=slnt>اْ</tajweed> ءَايَ<tajweed class=idgham_ghunnah>ةً ي</tajweed>َسْتَسْخِر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٤</span>"}, {"id": 15, "text": "وَقَال<tajweed class=madda_obligatory>ُوٓ</tajweed><tajweed class=slnt>اْ</tajweed> إِنْ هَ<tajweed class=madda_normal>ـٰ</tajweed>ذ<tajweed class=madda_obligatory>َآ</tajweed> إِلَّا سِحْ<tajweed class=idgham_ghunnah>رٌ م</tajweed>ُّب<tajweed class=madda_permissible>ِي</tajweed>نٌ <span class=end>١٥</span>"}, {"id": 16, "text": "أَءِذَا مِتْنَا وَكُ<tajweed class=ghunnah>نّ</tajweed>َا تُرَا<tajweed class=idgham_ghunnah>بًا و</tajweed>َعِظَ<tajweed class=madda_normal>ـٰ</tajweed>مًا أَءِ<tajweed class=ghunnah>نّ</tajweed>َا لَمَ<tajweed class=qalaqah>بْ</tajweed>عُوث<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٦</span>"}, {"id": 17, "text": "أَوَءَاب<tajweed class=madda_obligatory>َا</tajweed>ٓؤُنَا <tajweed class=ham_wasl>ٱ</tajweed>لْأَوَّل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٧</span>"}, {"id": 18, "text": "قُلْ نَعَمْ وَأَ<tajweed class=ikhafa>نت</tajweed>ُمْ د<tajweed class=madda_normal>َٲ</tajweed>خِر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٨</span>"}, {"id": 19, "text": "فَإِ<tajweed class=ghunnah>نّ</tajweed>َمَا هِىَ زَ<tajweed class=qalaqah>جْ</tajweed>رَ<tajweed class=idgham_ghunnah>ةٌ و</tajweed><tajweed class=madda_normal>َٲ</tajweed>حِدَ<tajweed class=ikhafa>ةٌ ف</tajweed>َإِذَا هُمْ يَ<tajweed class=ikhafa>نظ</tajweed>ُر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٩</span>"}, {"id": 20, "text": "وَقَالُو<tajweed class=slnt>اْ</tajweed> يَ<tajweed class=madda_normal>ـٰ</tajweed>وَيْلَنَا هَ<tajweed class=madda_normal>ـٰ</tajweed>ذَا يَوْمُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>دّ<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٢٠</span>"}, {"id": 21, "text": "هَ<tajweed class=madda_normal>ـٰ</tajweed>ذَا يَوْمُ <tajweed class=ham_wasl>ٱ</tajweed>لْفَصْلِ <tajweed class=ham_wasl>ٱ</tajweed>لَّذِى كُ<tajweed class=ikhafa>نت</tajweed><tajweed class=ikhafa_shafawi>ُم ب</tajweed>ِه<tajweed class=madda_normal>ِۦ</tajweed> تُكَذِّب<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢١</span>"}, {"id": 22, "text": "۞ ٱحْشُرُو<tajweed class=slnt>اْ</tajweed> <tajweed class=ham_wasl>ٱ</tajweed>لَّذِينَ ظَلَمُو<tajweed class=slnt>اْ</tajweed> وَأَزْو<tajweed class=madda_normal>َٲ</tajweed>جَهُمْ وَمَا كَانُو<tajweed class=slnt>اْ</tajweed> يَعْبُد<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٢</span>"}, {"id": 23, "text": "مِ<tajweed class=ikhafa>ن د</tajweed>ُونِ <tajweed class=ham_wasl>ٱ</tajweed>للَّهِ فَ<tajweed class=ham_wasl>ٱ</tajweed>هْدُوهُمْ إِلَىٰ صِر<tajweed class=madda_normal>َٲ</tajweed>طِ <tajweed class=ham_wasl>ٱ</tajweed>لْجَح<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٢٣</span>"}, {"id": 24, "text": "وَقِفُوهُمْ‌ۖ إِ<tajweed class=ghunnah>نّ</tajweed>َه<tajweed class=idgham_shafawi>ُم م</tajweed>َّسْــُٔول<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٤</span>"}, {"id": 25, "text": "مَا لَكُمْ لَا تَنَاصَر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٥</span>"}, {"id": 26, "text": "بَلْ هُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْيَوْمَ مُسْتَسْلِم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٦</span>"}, {"id": 27, "text": "وَأَ<tajweed class=qalaqah>قْ</tajweed>بَلَ بَعْضُهُمْ عَلَىٰ بَعْ<tajweed class=idgham_ghunnah>ضٍ ي</tajweed>َتَس<tajweed class=madda_obligatory>َا</tajweed>ٓءَل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٧</span>"}, {"id": 28, "text": "قَال<tajweed class=madda_obligatory>ُوٓ</tajweed><tajweed class=slnt>اْ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َكُمْ كُ<tajweed class=ikhafa>نت</tajweed>ُمْ تَأْتُونَنَا عَنِ <tajweed class=ham_wasl>ٱ</tajweed>لْيَم<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٢٨</span>"}, {"id": 29, "text": "قَالُو<tajweed class=slnt>اْ</tajweed> بَل لَّمْ تَكُونُو<tajweed class=slnt>اْ</tajweed> مُؤْمِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٢٩</span>"}, {"id": 30, "text": "وَمَا كَانَ لَنَا عَلَيْك<tajweed class=idgham_shafawi>ُم م</tajweed>ِّ<tajweed class=ikhafa>ن س</tajweed>ُلْطَ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=iqlab>نِۭ‌ۖ ب</tajweed>َلْ كُ<tajweed class=ikhafa>نت</tajweed>ُمْ قَوْ<tajweed class=ikhafa>مًا ط</tajweed>َ<tajweed class=madda_normal>ـٰ</tajweed>غ<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٠</span>"}, {"id": 31, "text": "فَحَقَّ عَلَيْنَا قَوْلُ رَبِّن<tajweed class=madda_obligatory>َآ‌ۖ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َا لَذ<tajweed class=madda_obligatory>َا</tajweed>ٓئِق<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣١</span>"}, {"id": 32, "text": "فَأَغْوَيْنَ<tajweed class=madda_normal>ـٰ</tajweed>كُمْ إِ<tajweed class=ghunnah>نّ</tajweed>َا كُ<tajweed class=ghunnah>نّ</tajweed>َا غَ<tajweed class=madda_normal>ـٰ</tajweed>و<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٢</span>"}, {"id": 33, "text": "فَإِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ يَوْمَئِ<tajweed class=ikhafa>ذٍ ف</tajweed>ِى <tajweed class=ham_wasl>ٱ</tajweed>لْعَذَابِ مُشْتَرِك<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٣</span>"}, {"id": 34, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َا كَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ نَفْعَلُ بِ<tajweed class=ham_wasl>ٱ</tajweed>لْمُ<tajweed class=qalaqah>جْ</tajweed>رِم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٤</span>"}, {"id": 35, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ كَان<tajweed class=madda_obligatory>ُوٓ</tajweed><tajweed class=slnt>اْ</tajweed> إِذَا قِيلَ لَهُمْ ل<tajweed class=madda_obligatory>َآ</tajweed> إِلَ<tajweed class=madda_normal>ـٰ</tajweed>هَ إِلَّا <tajweed class=ham_wasl>ٱ</tajweed>للَّهُ يَسْتَكْبِر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٥</span>"}, {"id": 36, "text": "وَيَقُولُونَ أَئِ<tajweed class=ghunnah>نّ</tajweed>َا لَتَارِك<tajweed class=madda_obligatory>ُوٓ</tajweed><tajweed class=slnt>اْ</tajweed> ءَالِهَتِنَا لِشَاعِ<tajweed class=idgham_ghunnah>رٍ م</tajweed>َّ<tajweed class=qalaqah>جْ</tajweed>ن<tajweed class=madda_permissible>ُو</tajweed>نِۭ <span class=end>٣٦</span>"}, {"id": 37, "text": "بَلْ ج<tajweed class=madda_obligatory>َا</tajweed>ٓءَ بِ<tajweed class=ham_wasl>ٱ</tajweed>لْحَقِّ وَصَدَّقَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُرْسَل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٧</span>"}, {"id": 38, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َكُمْ لَذ<tajweed class=madda_obligatory>َا</tajweed>ٓئِقُو<tajweed class=slnt>اْ</tajweed> <tajweed class=ham_wasl>ٱ</tajweed>لْعَذَابِ <tajweed class=ham_wasl>ٱ</tajweed>لْأَل<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٣٨</span>"}, {"id": 39, "text": "وَمَا تُ<tajweed class=qalaqah>جْ</tajweed>زَوْنَ إِلَّا مَا كُ<tajweed class=ikhafa>نت</tajweed>ُمْ تَعْمَل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٩</span>"}, {"id": 40, "text": "إِلَّا عِبَادَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهِ <tajweed class=ham_wasl>ٱ</tajweed>لْمُخْلَص<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٤٠</span>"}, {"id": 41, "text": "أُ<tajweed class=slnt>وْ</tajweed>لَ<tajweed class=madda_obligatory>ـٰٓ</tajweed>ئِكَ لَهُمْ رِزْ<tajweed class=idgham_ghunnah>قٌ م</tajweed>َّعْل<tajweed class=madda_permissible>ُو</tajweed>مٌ <span class=end>٤١</span>"}, {"id": 42, "text": "فَو<tajweed class=madda_normal>َٲ</tajweed>كِهُ‌ۖ وَه<tajweed class=idgham_shafawi>ُم م</tajweed>ُّكْرَم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٤٢</span>"}, {"id": 43, "text": "فِى جَ<tajweed class=ghunnah>نّ</tajweed>َ<tajweed class=madda_normal>ـٰ</tajweed>تِ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed><tajweed class=ghunnah>نّ</tajweed>َع<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٤٣</span>"}, {"id": 44, "text": "عَلَىٰ سُرُ<tajweed class=idgham_ghunnah>رٍ م</tajweed>ُّتَقَ<tajweed class=madda_normal>ـٰ</tajweed>بِل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٤٤</span>"}, {"id": 45, "text": "يُطَافُ عَلَيْه<tajweed class=ikhafa_shafawi>ِم ب</tajweed>ِكَأْ<tajweed class=idgham_ghunnah>سٍ م</tajweed>ّ<tajweed class=idgham_ghunnah>ِن م</tajweed>َّع<tajweed class=madda_permissible>ِي</tajweed>نِۭ <span class=end>٤٥</span>"}, {"id": 46, "text": "بَيْض<tajweed class=madda_obligatory>َا</tajweed>ٓءَ لَذَّ<tajweed class=idgham_wo_ghunnah>ةٍ ل</tajweed>ِّلشَّ<tajweed class=madda_normal>ـٰ</tajweed>رِب<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٤٦</span>"}, {"id": 47, "text": "لَا فِيهَا غَوْ<tajweed class=idgham_ghunnah>لٌ و</tajweed>َلَا هُمْ عَنْهَا يُ<tajweed class=ikhafa>نز</tajweed>َف<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٤٧</span>"}, {"id": 48, "text": "وَعِ<tajweed class=ikhafa>ند</tajweed>َهُمْ قَ<tajweed class=madda_normal>ـٰ</tajweed>صِر<tajweed class=madda_normal>َٲ</tajweed>تُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>طَّرْفِ ع<tajweed class=madda_permissible>ِي</tajweed>نٌ <span class=end>٤٨</span>"}, {"id": 49, "text": "كَأَ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=ghunnah>نّ</tajweed>َ بَيْ<tajweed class=idgham_ghunnah>ضٌ م</tajweed>َّكْن<tajweed class=madda_permissible>ُو</tajweed>نٌ <span class=end>٤٩</span>"}, {"id": 50, "text": "فَأَ<tajweed class=qalaqah>قْ</tajweed>بَلَ بَعْضُهُمْ عَلَىٰ بَعْ<tajweed class=idgham_ghunnah>ضٍ ي</tajweed>َتَس<tajweed class=madda_obligatory>َا</tajweed>ٓءَل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥٠</span>"}, {"id": 51, "text": "قَالَ ق<tajweed class=madda_obligatory>َا</tajweed>ٓئِ<tajweed class=idgham_ghunnah>لٌ م</tajweed>ِّنْهُمْ إِ<tajweed class=ghunnah>نّ</tajweed>ِى كَانَ لِى قَر<tajweed class=madda_permissible>ِي</tajweed>نٌ <span class=end>٥١</span>"}, {"id": 52, "text": "يَقُولُ أَءِ<tajweed class=ghunnah>نّ</tajweed>َكَ لَمِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُصَدِّق<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٥٢</span>"}, {"id": 53, "text": "أَءِذَا مِتْنَا وَكُ<tajweed class=ghunnah>نّ</tajweed>َا تُرَا<tajweed class=idgham_ghunnah>بًا و</tajweed>َعِظَ<tajweed class=madda_normal>ـٰ</tajweed>مًا أَءِ<tajweed class=ghunnah>نّ</tajweed>َا لَمَدِين<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥٣</span>"}, {"id": 54, "text": "قَالَ هَلْ أَ<tajweed class=ikhafa>نت</tajweed><tajweed class=idgham_shafawi>ُم م</tajweed>ُّطَّلِع<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥٤</span>"}, {"id": 55, "text": "فَ<tajweed class=ham_wasl>ٱ</tajweed>طَّلَعَ فَرَءَاهُ فِى سَو<tajweed class=madda_obligatory>َا</tajweed>ٓءِ <tajweed class=ham_wasl>ٱ</tajweed>لْجَح<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٥٥</span>"}, {"id": 56, "text": "قَالَ تَ<tajweed class=ham_wasl>ٱ</tajweed>للَّهِ إِ<tajweed class=ikhafa>ن ك</tajweed>ِ<tajweed class=idgham_mutajanisayn>د</tajweed>تَّ لَتُرْد<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٥٦</span>"}, {"id": 57, "text": "وَلَوْلَا نِعْمَةُ رَبِّى لَكُ<tajweed class=ikhafa>نت</tajweed>ُ مِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُحْضَر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٥٧</span>"}, {"id": 58, "text": "أَفَمَا نَحْنُ بِمَيِّت<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٥٨</span>"}, {"id": 59, "text": "إِلَّا مَوْتَتَنَا <tajweed class=ham_wasl>ٱ</tajweed>لْأُولَىٰ وَمَا نَحْنُ بِمُعَذَّب<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٥٩</span>"}, {"id": 60, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َ هَ<tajweed class=madda_normal>ـٰ</tajweed>ذَا لَهُوَ <tajweed class=ham_wasl>ٱ</tajweed>لْفَوْزُ <tajweed class=ham_wasl>ٱ</tajweed>لْعَظ<tajweed class=madda_permissible>ِي</tajweed>مُ <span class=end>٦٠</span>"}, {"id": 61, "text": "لِمِثْلِ هَ<tajweed class=madda_normal>ـٰ</tajweed>ذَا فَلْيَعْمَلِ <tajweed class=ham_wasl>ٱ</tajweed>لْعَ<tajweed class=madda_normal>ـٰ</tajweed>مِل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٦١</span>"}, {"id": 62, "text": "أَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ خَيْ<tajweed class=idgham_ghunnah>رٌ ن</tajweed>ُّزُلاً أَمْ شَجَرَةُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>زَّقّ<tajweed class=madda_permissible>ُو</tajweed>مِ <span class=end>٦٢</span>"}, {"id": 63, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َا جَعَلْنَ<tajweed class=madda_normal>ـٰ</tajweed>هَا فِتْنَ<tajweed class=idgham_wo_ghunnah>ةً ل</tajweed>ِّلظَّ<tajweed class=madda_normal>ـٰ</tajweed>لِم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٦٣</span>"}, {"id": 64, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َهَا شَجَرَ<tajweed class=ikhafa>ةٌ ت</tajweed>َخْرُجُ ف<tajweed class=madda_obligatory>ِىٓ</tajweed> أَصْلِ <tajweed class=ham_wasl>ٱ</tajweed>لْجَح<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٦٤</span>"}, {"id": 65, "text": "طَلْعُهَا كَأَ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=madda_normal>ۥ</tajweed> رُءُوسُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>شَّيَ<tajweed class=madda_normal>ـٰ</tajweed>ط<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٦٥</span>"}, {"id": 66, "text": "فَإِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ لَأَكِلُونَ مِنْهَا فَمَالِــُٔونَ مِنْهَا <tajweed class=ham_wasl>ٱ</tajweed>لْبُط<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٦٦</span>"}, {"id": 67, "text": "ثُ<tajweed class=ghunnah>مّ</tajweed>َ إِ<tajweed class=ghunnah>نّ</tajweed>َ لَهُمْ عَلَيْهَا لَشَوْ<tajweed class=idgham_ghunnah>بًا م</tajweed>ِّنْ حَم<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>٦٧</span>"}, {"id": 68, "text": "ثُ<tajweed class=ghunnah>مّ</tajweed>َ إِ<tajweed class=ghunnah>نّ</tajweed>َ مَرْجِعَهُمْ لَإِلَى <tajweed class=ham_wasl>ٱ</tajweed>لْجَح<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٦٨</span>"}, {"id": 69, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ أَلْفَوْ<tajweed class=slnt>اْ</tajweed> ءَاب<tajweed class=madda_obligatory>َا</tajweed>ٓءَهُمْ ض<tajweed class=madda_necessary>َا</tajweed>ٓلّ<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٦٩</span>"}, {"id": 70, "text": "فَهُمْ عَلَ<tajweed class=madda_obligatory>ىٰٓ</tajweed> ءَاثَ<tajweed class=madda_normal>ـٰ</tajweed>رِهِمْ يُهْرَع<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٧٠</span>"}, {"id": 71, "text": "وَلَقَ<tajweed class=qalaqah>دْ</tajweed> ضَلَّ قَ<tajweed class=qalaqah>بْ</tajweed>لَهُمْ أَكْثَرُ <tajweed class=ham_wasl>ٱ</tajweed>لْأَوَّل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٧١</span>"}, {"id": 72, "text": "وَلَقَ<tajweed class=qalaqah>دْ</tajweed> أَرْسَلْنَا فِيه<tajweed class=idgham_shafawi>ِم م</tajweed>ُّ<tajweed class=ikhafa>نذ</tajweed>ِر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٧٢</span>"}, {"id": 73, "text": "فَ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=ikhafa>نظ</tajweed>ُرْ كَيْفَ كَانَ عَ<tajweed class=madda_normal>ـٰ</tajweed>قِبَةُ <tajweed class=ham_wasl>ٱ</tajweed>لْمُ<tajweed class=ikhafa>نذ</tajweed>َر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٧٣</span>"}, {"id": 74, "text": "إِلَّا عِبَادَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهِ <tajweed class=ham_wasl>ٱ</tajweed>لْمُخْلَص<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٧٤</span>"}, {"id": 75, "text": "وَلَقَ<tajweed class=qalaqah>دْ</tajweed> نَادَ<tajweed class=madda_normal>ٮٰ</tajweed>نَا نُو<tajweed class=ikhafa>حٌ ف</tajweed>َلَنِعْمَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُجِيب<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٧٥</span>"}, {"id": 76, "text": "وَنَجَّيْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ وَأَهْلَهُ<tajweed class=madda_normal>ۥ</tajweed> مِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْكَرْبِ <tajweed class=ham_wasl>ٱ</tajweed>لْعَظ<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٧٦</span>"}, {"id": 77, "text": "وَجَعَلْنَا ذُرِّيَّتَهُ<tajweed class=madda_normal>ۥ</tajweed> هُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْبَاق<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٧٧</span>"}, {"id": 78, "text": "وَتَرَكْنَا عَلَيْهِ فِى <tajweed class=ham_wasl>ٱ</tajweed>لْأَخِر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٧٨</span>"}, {"id": 79, "text": "سَلَ<tajweed class=madda_normal>ـٰ</tajweed>مٌ عَلَىٰ نُو<tajweed class=ikhafa>حٍ ف</tajweed>ِى <tajweed class=ham_wasl>ٱ</tajweed>لْعَ<tajweed class=madda_normal>ـٰ</tajweed>لَم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٧٩</span>"}, {"id": 80, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َا كَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ نَ<tajweed class=qalaqah>جْ</tajweed>زِى <tajweed class=ham_wasl>ٱ</tajweed>لْمُحْسِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٨٠</span>"}, {"id": 81, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=madda_normal>ۥ</tajweed> مِنْ عِبَادِنَا <tajweed class=ham_wasl>ٱ</tajweed>لْمُؤْمِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٨١</span>"}, {"id": 82, "text": "ثُ<tajweed class=ghunnah>مّ</tajweed>َ أَغْرَ<tajweed class=qalaqah>قْ</tajweed>نَا <tajweed class=ham_wasl>ٱ</tajweed>لْأَخَر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٨٢</span>"}, {"id": 83, "text": "۞ وَإِ<tajweed class=ghunnah>نّ</tajweed>َ مِ<tajweed class=ikhafa>ن ش</tajweed>ِيعَتِه<tajweed class=madda_normal>ِۦ</tajweed> لَإِ<tajweed class=qalaqah>بْ</tajweed>ر<tajweed class=madda_normal>َٲ</tajweed>ه<tajweed class=madda_permissible>ِي</tajweed>مَ <span class=end>٨٣</span>"}, {"id": 84, "text": "إِذْ ج<tajweed class=madda_obligatory>َا</tajweed>ٓءَ رَبَّهُ<tajweed class=madda_normal>ۥ</tajweed> بِقَلْ<tajweed class=ikhafa>بٍ س</tajweed>َل<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>٨٤</span>"}, {"id": 85, "text": "إِذْ قَالَ لِأَبِيهِ وَقَوْمِه<tajweed class=madda_normal>ِۦ</tajweed> مَاذَا تَعْبُد<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٨٥</span>"}, {"id": 86, "text": "أَئِفْكًا ءَالِهَ<tajweed class=ikhafa>ةً د</tajweed>ُونَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهِ تُرِيد<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٨٦</span>"}, {"id": 87, "text": "فَمَا ظَ<tajweed class=ghunnah>نّ</tajweed>ُك<tajweed class=ikhafa_shafawi>ُم ب</tajweed>ِرَبِّ <tajweed class=ham_wasl>ٱ</tajweed>لْعَ<tajweed class=madda_normal>ـٰ</tajweed>لَم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٨٧</span>"}, {"id": 88, "text": "فَنَظَرَ نَظْرَ<tajweed class=ikhafa>ةً ف</tajweed>ِى <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed><tajweed class=ghunnah>نّ</tajweed>ُج<tajweed class=madda_permissible>ُو</tajweed>مِ <span class=end>٨٨</span>"}, {"id": 89, "text": "فَقَالَ إِ<tajweed class=ghunnah>نّ</tajweed>ِى سَق<tajweed class=madda_permissible>ِي</tajweed>مٌ <span class=end>٨٩</span>"}, {"id": 90, "text": "فَتَوَلَّوْ<tajweed class=slnt>اْ</tajweed> عَنْهُ مُ<tajweed class=qalaqah>دْ</tajweed>بِر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٩٠</span>"}, {"id": 91, "text": "فَرَاغَ إِلَ<tajweed class=madda_obligatory>ىٰٓ</tajweed> ءَالِهَتِهِمْ فَقَالَ أَلَا تَأْكُل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٩١</span>"}, {"id": 92, "text": "مَا لَكُمْ لَا تَ<tajweed class=ikhafa>نط</tajweed>ِق<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٩٢</span>"}, {"id": 93, "text": "فَرَاغَ عَلَيْهِمْ ضَرْب<tajweed class=iqlab>َۢا ب</tajweed>ِ<tajweed class=ham_wasl>ٱ</tajweed>لْيَم<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٩٣</span>"}, {"id": 94, "text": "فَأَ<tajweed class=qalaqah>قْ</tajweed>بَل<tajweed class=madda_obligatory>ُوٓ</tajweed><tajweed class=slnt>اْ</tajweed> إِلَيْهِ يَزِفّ<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٩٤</span>"}, {"id": 95, "text": "قَالَ أَتَعْبُدُونَ مَا تَنْحِت<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٩٥</span>"}, {"id": 96, "text": "وَ<tajweed class=ham_wasl>ٱ</tajweed>للَّهُ خَلَقَكُمْ وَمَا تَعْمَل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٩٦</span>"}, {"id": 97, "text": "قَالُو<tajweed class=slnt>اْ</tajweed> <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=qalaqah>بْ</tajweed>نُو<tajweed class=slnt>اْ</tajweed> لَهُ<tajweed class=madda_normal>ۥ</tajweed> بُنْيَ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=ikhafa>نًا ف</tajweed>َأَلْقُوهُ فِى <tajweed class=ham_wasl>ٱ</tajweed>لْجَح<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٩٧</span>"}, {"id": 98, "text": "فَأَرَادُو<tajweed class=slnt>اْ</tajweed> بِه<tajweed class=madda_normal>ِۦ</tajweed> كَيْ<tajweed class=ikhafa>دًا ف</tajweed>َجَعَلْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْأَسْفَل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٩٨</span>"}, {"id": 99, "text": "وَقَالَ إِ<tajweed class=ghunnah>نّ</tajweed>ِى ذَاهِبٌ إِلَىٰ رَبِّى سَيَهْد<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٩٩</span>"}, {"id": 100, "text": "رَبِّ هَ<tajweed class=qalaqah>بْ</tajweed> لِى مِنَ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>صَّ<tajweed class=madda_normal>ـٰ</tajweed>لِح<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٠٠</span>"}, {"id": 101, "text": "فَبَشَّرْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ بِغُلَ<tajweed class=madda_normal>ـٰ</tajweed>مٍ حَل<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>١٠١</span>"}, {"id": 102, "text": "فَلَ<tajweed class=ghunnah>مّ</tajweed>َا بَلَغَ مَعَهُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>سَّعْىَ قَالَ يَ<tajweed class=madda_normal>ـٰ</tajweed>بُنَىَّ إِ<tajweed class=ghunnah>نّ</tajweed><tajweed class=madda_obligatory>ِىٓ</tajweed> أَرَىٰ فِى <tajweed class=ham_wasl>ٱ</tajweed>لْمَنَامِ أَ<tajweed class=ghunnah>نّ</tajweed><tajweed class=madda_obligatory>ِىٓ</tajweed> أَذْبَحُكَ فَ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=ikhafa>نظ</tajweed>ُرْ مَاذَا تَرَىٰ‌ۚ قَالَ يَ<tajweed class=madda_obligatory>ـٰٓ</tajweed>أَبَتِ <tajweed class=ham_wasl>ٱ</tajweed>فْعَلْ مَا تُؤْمَرُ‌ۖ سَتَجِدُن<tajweed class=madda_obligatory>ِىٓ</tajweed> إِ<tajweed class=ikhafa>ن ش</tajweed><tajweed class=madda_obligatory>َا</tajweed>ٓءَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهُ مِنَ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>صَّ<tajweed class=madda_normal>ـٰ</tajweed>بِر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٠٢</span>"}, {"id": 103, "text": "فَلَ<tajweed class=ghunnah>مّ</tajweed><tajweed class=madda_obligatory>َآ</tajweed> أَسْلَمَا وَتَلَّهُ<tajweed class=madda_normal>ۥ</tajweed> لِلْجَب<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>١٠٣</span>"}, {"id": 104, "text": "وَنَ<tajweed class=madda_normal>ـٰ</tajweed>دَيْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ أ<tajweed class=idgham_ghunnah>َن ي</tajweed>َ<tajweed class=madda_obligatory>ـٰٓ</tajweed>إِ<tajweed class=qalaqah>بْ</tajweed>ر<tajweed class=madda_normal>َٲ</tajweed>ه<tajweed class=madda_permissible>ِي</tajweed>مُ <span class=end>١٠٤</span>"}, {"id": 105, "text": "قَ<tajweed class=qalaqah>دْ</tajweed> صَدَّ<tajweed class=qalaqah>قْ</tajweed>تَ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>رُّءْي<tajweed class=madda_obligatory>َآ‌ۚ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َا كَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ نَ<tajweed class=qalaqah>جْ</tajweed>زِى <tajweed class=ham_wasl>ٱ</tajweed>لْمُحْسِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٠٥</span>"}, {"id": 106, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َ هَ<tajweed class=madda_normal>ـٰ</tajweed>ذَا لَهُوَ <tajweed class=ham_wasl>ٱ</tajweed>لْبَلَ<tajweed class=madda_obligatory>ـٰٓ</tajweed>ؤُ<tajweed class=slnt>اْ</tajweed> <tajweed class=ham_wasl>ٱ</tajweed>لْمُب<tajweed class=madda_permissible>ِي</tajweed>نُ <span class=end>١٠٦</span>"}, {"id": 107, "text": "وَفَدَيْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ بِذِ<tajweed class=qalaqah>بْ</tajweed>حٍ عَظ<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>١٠٧</span>"}, {"id": 108, "text": "وَتَرَكْنَا عَلَيْهِ فِى <tajweed class=ham_wasl>ٱ</tajweed>لْأَخِر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٠٨</span>"}, {"id": 109, "text": "سَلَ<tajweed class=madda_normal>ـٰ</tajweed>مٌ عَلَ<tajweed class=madda_obligatory>ىٰٓ</tajweed> إِ<tajweed class=qalaqah>بْ</tajweed>ر<tajweed class=madda_normal>َٲ</tajweed>ه<tajweed class=madda_permissible>ِي</tajweed>مَ <span class=end>١٠٩</span>"}, {"id": 110, "text": "كَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ نَ<tajweed class=qalaqah>جْ</tajweed>زِى <tajweed class=ham_wasl>ٱ</tajweed>لْمُحْسِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١١٠</span>"}, {"id": 111, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=madda_normal>ۥ</tajweed> مِنْ عِبَادِنَا <tajweed class=ham_wasl>ٱ</tajweed>لْمُؤْمِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١١١</span>"}, {"id": 112, "text": "وَبَشَّرْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ بِإِسْحَ<tajweed class=madda_normal>ـٰ</tajweed>قَ نَبِي<tajweed class=idgham_ghunnah>ًّا م</tajweed>ِّنَ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>صَّ<tajweed class=madda_normal>ـٰ</tajweed>لِح<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١١٢</span>"}, {"id": 113, "text": "وَبَ<tajweed class=madda_normal>ـٰ</tajweed>رَكْنَا عَلَيْهِ وَعَلَ<tajweed class=madda_obligatory>ىٰٓ</tajweed> إِسْحَ<tajweed class=madda_normal>ـٰ</tajweed>قَ‌ۚ وَمِ<tajweed class=ikhafa>ن ذ</tajweed>ُرِّيَّتِهِمَا مُحْسِ<tajweed class=idgham_ghunnah>نٌ و</tajweed>َظَالِ<tajweed class=idgham_wo_ghunnah>مٌ ل</tajweed>ِّنَفْسِه<tajweed class=madda_normal>ِۦ</tajweed> مُب<tajweed class=madda_permissible>ِي</tajweed>نٌ <span class=end>١١٣</span>"}, {"id": 114, "text": "وَلَقَ<tajweed class=qalaqah>دْ</tajweed> مَنَ<tajweed class=ghunnah>نّ</tajweed>َا عَلَىٰ مُوسَىٰ وَهَ<tajweed class=madda_normal>ـٰ</tajweed>ر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١١٤</span>"}, {"id": 115, "text": "وَنَجَّيْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُمَا وَقَوْمَهُمَا مِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْكَرْبِ <tajweed class=ham_wasl>ٱ</tajweed>لْعَظ<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>١١٥</span>"}, {"id": 116, "text": "وَنَصَرْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُمْ فَكَانُو<tajweed class=slnt>اْ</tajweed> هُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْغَ<tajweed class=madda_normal>ـٰ</tajweed>لِب<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١١٦</span>"}, {"id": 117, "text": "وَءَاتَيْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُمَا <tajweed class=ham_wasl>ٱ</tajweed>لْكِتَ<tajweed class=madda_normal>ـٰ</tajweed>بَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُسْتَب<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١١٧</span>"}, {"id": 118, "text": "وَهَدَيْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُمَا <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>صِّر<tajweed class=madda_normal>َٲ</tajweed>طَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُسْتَق<tajweed class=madda_permissible>ِي</tajweed>مَ <span class=end>١١٨</span>"}, {"id": 119, "text": "وَتَرَكْنَا عَلَيْهِمَا فِى <tajweed class=ham_wasl>ٱ</tajweed>لْأَخِر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١١٩</span>"}, {"id": 120, "text": "سَلَ<tajweed class=madda_normal>ـٰ</tajweed>مٌ عَلَىٰ مُوسَىٰ وَهَ<tajweed class=madda_normal>ـٰ</tajweed>ر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٢٠</span>"}, {"id": 121, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َا كَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ نَ<tajweed class=qalaqah>جْ</tajweed>زِى <tajweed class=ham_wasl>ٱ</tajweed>لْمُحْسِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٢١</span>"}, {"id": 122, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َهُمَا مِنْ عِبَادِنَا <tajweed class=ham_wasl>ٱ</tajweed>لْمُؤْمِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٢٢</span>"}, {"id": 123, "text": "وَإِ<tajweed class=ghunnah>نّ</tajweed>َ إِلْيَاسَ لَمِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُرْسَل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٢٣</span>"}, {"id": 124, "text": "إِذْ قَالَ لِقَوْمِه<tajweed class=madda_obligatory>ِۦٓ</tajweed> أَلَا تَتَّق<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٢٤</span>"}, {"id": 125, "text": "أَتَ<tajweed class=qalaqah>دْ</tajweed>عُونَ بَعْل<tajweed class=idgham_ghunnah>اً و</tajweed>َتَذَرُونَ أَحْسَنَ <tajweed class=ham_wasl>ٱ</tajweed>لْخَ<tajweed class=madda_normal>ـٰ</tajweed>لِق<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٢٥</span>"}, {"id": 126, "text": "ٱللَّهَ رَبَّكُمْ وَرَبَّ ءَاب<tajweed class=madda_obligatory>َا</tajweed>ٓئِكُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْأَوَّل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٢٦</span>"}, {"id": 127, "text": "فَكَذَّبُوهُ فَإِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ لَمُحْضَر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٢٧</span>"}, {"id": 128, "text": "إِلَّا عِبَادَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهِ <tajweed class=ham_wasl>ٱ</tajweed>لْمُخْلَص<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٢٨</span>"}, {"id": 129, "text": "وَتَرَكْنَا عَلَيْهِ فِى <tajweed class=ham_wasl>ٱ</tajweed>لْأَخِر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٢٩</span>"}, {"id": 130, "text": "سَلَ<tajweed class=madda_normal>ـٰ</tajweed>مٌ عَلَ<tajweed class=madda_obligatory>ىٰٓ</tajweed> إِلْ يَاس<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٣٠</span>"}, {"id": 131, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َا كَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ نَ<tajweed class=qalaqah>جْ</tajweed>زِى <tajweed class=ham_wasl>ٱ</tajweed>لْمُحْسِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٣١</span>"}, {"id": 132, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=madda_normal>ۥ</tajweed> مِنْ عِبَادِنَا <tajweed class=ham_wasl>ٱ</tajweed>لْمُؤْمِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٣٢</span>"}, {"id": 133, "text": "وَإِ<tajweed class=ghunnah>نّ</tajweed>َ لُو<tajweed class=idgham_wo_ghunnah>طًا ل</tajweed>َّمِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُرْسَل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٣٣</span>"}, {"id": 134, "text": "إِذْ نَجَّيْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ وَأَهْلَهُ<tajweed class=madda_obligatory>ۥٓ</tajweed> أَ<tajweed class=qalaqah>جْ</tajweed>مَع<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٣٤</span>"}, {"id": 135, "text": "إِلَّا عَجُو<tajweed class=ikhafa>زًا ف</tajweed>ِى <tajweed class=ham_wasl>ٱ</tajweed>لْغَ<tajweed class=madda_normal>ـٰ</tajweed>بِر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٣٥</span>"}, {"id": 136, "text": "ثُ<tajweed class=ghunnah>مّ</tajweed>َ دَ<tajweed class=ghunnah>مّ</tajweed>َرْنَا <tajweed class=ham_wasl>ٱ</tajweed>لْأَخَر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٣٦</span>"}, {"id": 137, "text": "وَإِ<tajweed class=ghunnah>نّ</tajweed>َكُمْ لَتَمُرُّونَ عَلَيْه<tajweed class=idgham_shafawi>ِم م</tajweed>ُّصْبِح<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٣٧</span>"}, {"id": 138, "text": "وَبِ<tajweed class=ham_wasl>ٱ</tajweed>لَّيْلِ‌ۗ أَفَلَا تَعْقِل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٣٨</span>"}, {"id": 139, "text": "وَإِ<tajweed class=ghunnah>نّ</tajweed>َ يُونُسَ لَمِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُرْسَل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٣٩</span>"}, {"id": 140, "text": "إِذْ أَبَقَ إِلَى <tajweed class=ham_wasl>ٱ</tajweed>لْفُلْكِ <tajweed class=ham_wasl>ٱ</tajweed>لْمَشْح<tajweed class=madda_permissible>ُو</tajweed>نِ <span class=end>١٤٠</span>"}, {"id": 141, "text": "فَسَاهَمَ فَكَانَ مِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُ<tajweed class=qalaqah>دْ</tajweed>حَض<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٤١</span>"}, {"id": 142, "text": "فَ<tajweed class=ham_wasl>ٱ</tajweed>لْتَقَمَهُ <tajweed class=ham_wasl>ٱ</tajweed>لْحُوتُ وَهُوَ مُل<tajweed class=madda_permissible>ِي</tajweed>مٌ <span class=end>١٤٢</span>"}, {"id": 143, "text": "فَلَوْل<tajweed class=madda_obligatory>َآ</tajweed> أَ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=madda_normal>ۥ</tajweed> كَانَ مِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُسَبِّح<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٤٣</span>"}, {"id": 144, "text": "لَلَبِثَ فِى بَ<tajweed class=qalaqah>طْ</tajweed>نِه<tajweed class=madda_obligatory>ِۦٓ</tajweed> إِلَىٰ يَوْمِ يُ<tajweed class=qalaqah>بْ</tajweed>عَث<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٤٤</span>"}, {"id": 145, "text": "۞ فَنَبَذْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ بِ<tajweed class=ham_wasl>ٱ</tajweed>لْعَر<tajweed class=madda_obligatory>َا</tajweed>ٓءِ وَهُوَ سَق<tajweed class=madda_permissible>ِي</tajweed>مٌ <span class=end>١٤٥</span>"}, {"id": 146, "text": "وَأَ<tajweed class=iqlab>نۢب</tajweed>َتْنَا عَلَيْهِ شَجَرَ<tajweed class=idgham_ghunnah>ةً م</tajweed>ّ<tajweed class=idgham_ghunnah>ِن ي</tajweed>َ<tajweed class=qalaqah>قْ</tajweed>ط<tajweed class=madda_permissible>ِي</tajweed>نٍ <span class=end>١٤٦</span>"}, {"id": 147, "text": "وَأَرْسَلْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ إِلَىٰ مِ<tajweed class=slnt>اْ</tajweed>ئَةِ أَلْفٍ أَوْ يَزِيد<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٤٧</span>"}, {"id": 148, "text": "فَـَٔـامَنُو<tajweed class=slnt>اْ</tajweed> فَمَتَّعْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُمْ إِلَىٰ ح<tajweed class=madda_permissible>ِي</tajweed>نٍ <span class=end>١٤٨</span>"}, {"id": 149, "text": "فَ<tajweed class=ham_wasl>ٱ</tajweed>سْتَفْتِهِمْ أَلِرَبِّكَ <tajweed class=ham_wasl>ٱ</tajweed>لْبَنَاتُ وَلَهُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْبَن<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٤٩</span>"}, {"id": 150, "text": "أَمْ خَلَ<tajweed class=qalaqah>قْ</tajweed>نَا <tajweed class=ham_wasl>ٱ</tajweed>لْمَلَ<tajweed class=madda_obligatory>ـٰٓ</tajweed>ئِكَةَ إِنَ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=idgham_ghunnah>ثًا و</tajweed>َهُمْ شَ<tajweed class=madda_normal>ـٰ</tajweed>هِد<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٥٠</span>"}, {"id": 151, "text": "أَل<tajweed class=madda_obligatory>َآ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َه<tajweed class=idgham_shafawi>ُم م</tajweed>ِّنْ إِفْكِهِمْ لَيَقُول<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٥١</span>"}, {"id": 152, "text": "وَلَدَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهُ وَإِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ لَكَ<tajweed class=madda_normal>ـٰ</tajweed>ذِب<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٥٢</span>"}, {"id": 153, "text": "أَصْطَفَى <tajweed class=ham_wasl>ٱ</tajweed>لْبَنَاتِ عَلَى <tajweed class=ham_wasl>ٱ</tajweed>لْبَن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٥٣</span>"}, {"id": 154, "text": "مَا لَكُمْ كَيْفَ تَحْكُم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٥٤</span>"}, {"id": 155, "text": "أَفَلَا تَذَكَّر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٥٥</span>"}, {"id": 156, "text": "أَمْ لَكُمْ سُلْطَ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=idgham_ghunnah>نٌ م</tajweed>ُّب<tajweed class=madda_permissible>ِي</tajweed>نٌ <span class=end>١٥٦</span>"}, {"id": 157, "text": "فَأْتُو<tajweed class=slnt>اْ</tajweed> بِكِتَ<tajweed class=madda_normal>ـٰ</tajweed>بِكُمْ إِ<tajweed class=ikhafa>ن ك</tajweed>ُ<tajweed class=ikhafa>نت</tajweed>ُمْ صَ<tajweed class=madda_normal>ـٰ</tajweed>دِق<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٥٧</span>"}, {"id": 158, "text": "وَجَعَلُو<tajweed class=slnt>اْ</tajweed> بَيْنَهُ<tajweed class=madda_normal>ۥ</tajweed> وَبَيْنَ <tajweed class=ham_wasl>ٱ</tajweed>لْجِ<tajweed class=ghunnah>نّ</tajweed>َةِ نَسَ<tajweed class=idgham_ghunnah>بًا‌ۚ و</tajweed>َلَقَ<tajweed class=qalaqah>دْ</tajweed> عَلِمَتِ <tajweed class=ham_wasl>ٱ</tajweed>لْجِ<tajweed class=ghunnah>نّ</tajweed>َةُ إِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ لَمُحْضَر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٥٨</span>"}, {"id": 159, "text": "سُ<tajweed class=qalaqah>بْ</tajweed>حَ<tajweed class=madda_normal>ـٰ</tajweed>نَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهِ عَ<tajweed class=ghunnah>مّ</tajweed>َا يَصِف<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٥٩</span>"}, {"id": 160, "text": "إِلَّا عِبَادَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهِ <tajweed class=ham_wasl>ٱ</tajweed>لْمُخْلَص<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٦٠</span>"}, {"id": 161, "text": "فَإِ<tajweed class=ghunnah>نّ</tajweed>َكُمْ وَمَا تَعْبُد<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٦١</span>"}, {"id": 162, "text": "م<tajweed class=madda_obligatory>َآ</tajweed> أَ<tajweed class=ikhafa>نت</tajweed>ُمْ عَلَيْهِ بِفَ<tajweed class=madda_normal>ـٰ</tajweed>تِن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٦٢</span>"}, {"id": 163, "text": "إِلَّا مَنْ هُوَ صَالِ <tajweed class=ham_wasl>ٱ</tajweed>لْجَح<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>١٦٣</span>"}, {"id": 164, "text": "وَمَا مِ<tajweed class=ghunnah>نّ</tajweed><tajweed class=madda_obligatory>َآ</tajweed> إِلَّا لَهُ<tajweed class=madda_normal>ۥ</tajweed> مَقَا<tajweed class=idgham_ghunnah>مٌ م</tajweed>َّعْل<tajweed class=madda_permissible>ُو</tajweed>مٌ <span class=end>١٦٤</span>"}, {"id": 165, "text": "وَإِ<tajweed class=ghunnah>نّ</tajweed>َا لَنَحْنُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>صّ<tajweed class=madda_necessary>َا</tajweed>ٓفّ<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٦٥</span>"}, {"id": 166, "text": "وَإِ<tajweed class=ghunnah>نّ</tajweed>َا لَنَحْنُ <tajweed class=ham_wasl>ٱ</tajweed>لْمُسَبِّح<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٦٦</span>"}, {"id": 167, "text": "وَإِ<tajweed class=ikhafa>ن ك</tajweed>َانُو<tajweed class=slnt>اْ</tajweed> لَيَقُول<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٦٧</span>"}, {"id": 168, "text": "لَوْ أَ<tajweed class=ghunnah>نّ</tajweed>َ عِ<tajweed class=ikhafa>ند</tajweed>َنَا ذِكْ<tajweed class=idgham_ghunnah>رًا م</tajweed>ِّنَ <tajweed class=ham_wasl>ٱ</tajweed>لْأَوَّل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٦٨</span>"}, {"id": 169, "text": "لَكُ<tajweed class=ghunnah>نّ</tajweed>َا عِبَادَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهِ <tajweed class=ham_wasl>ٱ</tajweed>لْمُخْلَص<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٦٩</span>"}, {"id": 170, "text": "فَكَفَرُو<tajweed class=slnt>اْ</tajweed> بِه<tajweed class=madda_normal>ِۦ</tajweed>‌ۖ فَسَوْفَ يَعْلَم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٧٠</span>"}, {"id": 171, "text": "وَلَقَ<tajweed class=qalaqah>دْ</tajweed> سَبَقَتْ كَلِمَتُنَا لِعِبَادِنَا <tajweed class=ham_wasl>ٱ</tajweed>لْمُرْسَل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٧١</span>"}, {"id": 172, "text": "إِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ لَهُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْمَ<tajweed class=ikhafa>نص</tajweed>ُور<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٧٢</span>"}, {"id": 173, "text": "وَإِ<tajweed class=ghunnah>نّ</tajweed>َ جُ<tajweed class=ikhafa>ند</tajweed>َنَا لَهُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْغَ<tajweed class=madda_normal>ـٰ</tajweed>لِب<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٧٣</span>"}, {"id": 174, "text": "فَتَوَلَّ عَنْهُمْ حَتَّىٰ ح<tajweed class=madda_permissible>ِي</tajweed>نٍ <span class=end>١٧٤</span>"}, {"id": 175, "text": "وَأَ<tajweed class=qalaqah>بْ</tajweed>صِرْهُمْ فَسَوْفَ يُ<tajweed class=qalaqah>بْ</tajweed>صِر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٧٥</span>"}, {"id": 176, "text": "أَفَبِعَذَابِنَا يَسْتَعْجِل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٧٦</span>"}, {"id": 177, "text": "فَإِذَا نَزَلَ بِسَاحَتِهِمْ فَس<tajweed class=madda_obligatory>َا</tajweed>ٓءَ صَبَاحُ <tajweed class=ham_wasl>ٱ</tajweed>لْمُ<tajweed class=ikhafa>نذ</tajweed>َر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٧٧</span>"}, {"id": 178, "text": "وَتَوَلَّ عَنْهُمْ حَتَّىٰ ح<tajweed class=madda_permissible>ِي</tajweed>نٍ <span class=end>١٧٨</span>"}, {"id": 179, "text": "وَأَ<tajweed class=qalaqah>بْ</tajweed>صِرْ فَسَوْفَ يُ<tajweed class=qalaqah>بْ</tajweed>صِر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٧٩</span>"}, {"id": 180, "text": "سُ<tajweed class=qalaqah>بْ</tajweed>حَ<tajweed class=madda_normal>ـٰ</tajweed>نَ رَبِّكَ رَبِّ <tajweed class=ham_wasl>ٱ</tajweed>لْعِزَّةِ عَ<tajweed class=ghunnah>مّ</tajweed>َا يَصِف<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٨٠</span>"}, {"id": 181, "text": "وَسَلَ<tajweed class=madda_normal>ـٰ</tajweed>مٌ عَلَى <tajweed class=ham_wasl>ٱ</tajweed>لْمُرْسَل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٨١</span>"}, {"id": 182, "text": "وَ<tajweed class=ham_wasl>ٱ</tajweed>لْحَمْدُ لِلَّهِ رَبِّ <tajweed class=ham_wasl>ٱ</tajweed>لْعَ<tajweed class=madda_normal>ـٰ</tajweed>لَم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٨٢</span>"}]}